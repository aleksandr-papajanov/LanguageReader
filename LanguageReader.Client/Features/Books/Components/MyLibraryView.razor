@inject BooksApiClient Api
@inject NavigationManager Navigation
@inject UserSession Session

<AppHeading Title="Add Book"
            Subtitle="Upload a private book first. After import we will take you straight to My Books." />

@if (!Session.IsSignedIn)
{
    <SignInPrompt />
}
else
{
    <BookUploadForm Title="@state.Title"
                    OriginalLanguage="@state.OriginalLanguage"
                    HasSelectedFile="@state.HasSelectedFile"
                    IsBusy="@state.IsBusy"
                    TitleChanged="@state.OnTitleChanged"
                    OriginalLanguageChanged="@state.OnOriginalLanguageChanged"
                    FileSelected="@state.OnFileSelected"
                    UploadClicked="UploadAsync" />

    @if (!string.IsNullOrWhiteSpace(state.Error))
    {
        <p class="app-inline-error">@state.Error</p>
    }
}

@code {
    private readonly BookUploadState state = new();

    private async Task UploadAsync()
    {
        await state.UploadAsync(Api, Navigation, Session.Username!);
    }
}
