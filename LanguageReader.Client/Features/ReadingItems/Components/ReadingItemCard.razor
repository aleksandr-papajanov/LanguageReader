@using LanguageReader.Client.Features.Common.Services.Viewport
@inject NavigationManager Navigation
@inject IViewportService Viewport
@inject ReaderWorkspaceService ReaderWorkspace
@implements IDisposable

<AppListItem AdditionalClass="reading-item-row">
    <ChildContent>
        <article class="reading-item-row__layout">
            <header class="reading-item-row__header">
                <div class="reading-item-row__media">
                    <div class="reading-item-row__thumb">
                        @if (!string.IsNullOrWhiteSpace(Item.ImageUrl))
                        {
                            <AppImage Src="@ResolveImageUrl(Item.ImageUrl)"
                                      Alt="@Item.Title"
                                      Decorative="true"
                                      Effect="AppImageEffect.Halftone"
                                      FillContainer="true"
                                      AdditionalClass="reading-item-row__thumb-media"
                                      ImageClass="reading-item-row__thumb-image" />
                        }
                        else
                        {
                            <div class="reading-item-row__thumb-fallback @(Item.Type == ReadingItemType.Article ? "reading-item-row__thumb-fallback--article" : "reading-item-row__thumb-fallback--book")">
                                <AppIcon Name="@(Item.Type == ReadingItemType.Article ? "newspaper" : "menu_book")" Size="28" />
                            </div>
                        }
                    </div>

                    @if (Item.ProgressPercent.HasValue)
                    {
                        <ReadingProgressCompact Value="@Item.ProgressPercent.Value"
                                                Status="@Item.ReadingStatus" />
                    }
                </div>

                <div class="reading-item-row__header-main"> 
                    <div class="reading-item-row__badges">
                        @if (!string.IsNullOrWhiteSpace(GetStatusLabel()))
                        {
                            <AppBadge Tone="@GetStatusTone()">@GetStatusLabel()</AppBadge>
                        }

                        <AppBadge Tone="@(Item.Type == ReadingItemType.Article ? "warning" : "info")">@GetTypeLabel()</AppBadge>

                        @if (Item.IsOwnedByCurrentUser || Item.IsPublic)
                        {
                            <AppBadge Tone="@(Item.IsOwnedByCurrentUser ? "success" : "default")">@(Item.IsOwnedByCurrentUser ? "Mine" : "Shared")</AppBadge>
                        }

                        @if (Item.IsInUserLibrary)
                        {
                            <AppBadge Tone="@(Item.IsPublic ? "success" : "default")">@(Item.IsPublic ? "Public" : "Private")</AppBadge>
                        }

                        @if (Item.Type == ReadingItemType.Article && (!string.IsNullOrWhiteSpace(Item.SourceKey) || !string.IsNullOrWhiteSpace(Item.SourceName)))
                        {
                            <ReadingItemSourceBadge SourceKey="@Item.SourceKey"
                                                    SourceName="@Item.SourceName" />
                        }
                    </div>

                    <div class="reading-item-row__dates">
                        <div class="reading-item-row__date">
                            <AppIcon Name="calendar_today" Size="16" />
                            <AppDateMeta Label="Created"
                                         Value="@Item.CreatedAtUtc"
                                         Format="ddd, d MMM" />
                        </div>

                        @if (Item.LastOpenedAtUtc.HasValue)
                        {
                            <div class="reading-item-row__date">
                                <AppIcon Name="history" Size="16" />
                                <AppDateMeta Label="Last opened"
                                             Value="@Item.LastOpenedAtUtc.Value"
                                             Format="ddd, d MMM" />
                            </div>
                        }
                    </div>
                </div>

                <div class="reading-item-row__actions">
                    @if (GetPrimaryActionLabel() is { } primaryLabel)
                    {
                        <AppButton Label="@primaryLabel"
                                   AdditionalClass="reading-item-row__continue-button"
                                   Variant="@GetPrimaryActionVariant()"
                                   Size="sm"
                                   Icon="@GetPrimaryActionIcon()"
                                   IconOnly="@Viewport.Current.IsMobile"
                                   Disabled="@Busy"
                                   OnClick="@(_ => HandlePrimaryActionAsync())" />
                    }

                    @if (MenuItems.Count > 0)
                    {
                        <AppDropdownMenu ButtonIcon="more_horiz"
                                         ButtonIconOnly="true"
                                         ButtonTitle="More actions"
                                         ButtonVariant="ghost"
                                         ButtonSize="sm"
                                         Align="end"
                                         Disabled="@Busy"
                                         Items="MenuItems"
                                         ItemSelected="HandleMenuActionAsync" />
                    }
                </div>
            </header>

            <section class="reading-item-row__content">
                <strong class="reading-item-row__title">@Item.Title</strong>

                @if (!string.IsNullOrWhiteSpace(GetDetails()))
                {
                    <div class="reading-item-row__meta">@GetDetails()</div>
                }

                @if (!string.IsNullOrWhiteSpace(Item.Excerpt))
                {
                    <div class="reading-item-row__excerpt">@Item.Excerpt</div>
                }
            </section>
        </article>
    </ChildContent>
</AppListItem>

@code {
    [Parameter, EditorRequired]
    public ReadingItemSummaryDto Item { get; set; } = null!;

    [Parameter]
    public bool Busy { get; set; }

    [Parameter]
    public EventCallback<ReadingItemSummaryDto> PrimaryActionSelected { get; set; }

    [Parameter]
    public EventCallback<ReadingItemSummaryDto> VisibilityToggleSelected { get; set; }

    [Parameter]
    public EventCallback<ReadingItemSummaryDto> DeleteSelected { get; set; }

    [Parameter]
    public EventCallback<ReadingItemSummaryDto> OpenOriginalSelected { get; set; }

    protected override void OnInitialized()
    {
        Viewport.Changed += HandleViewportChanged;
    }

    private void HandleViewportChanged(ViewportState state)
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Viewport.Changed -= HandleViewportChanged;
    }

    private async Task HandlePrimaryActionAsync()
    {
        if (PrimaryActionSelected.HasDelegate)
        {
            await PrimaryActionSelected.InvokeAsync(Item);
            return;
        }

        if (!Item.CanOpen && !Item.CanContinue)
        {
            return;
        }

        ReaderWorkspace.Open(Item.Id);
    }

    private string GetTypeLabel() => Item.Type == ReadingItemType.Article ? "Article" : "Book";

    private string ResolveImageUrl(string imageUrl)
    {
        return imageUrl;
    }

    private string? GetStatusLabel()
    {
        if (Item.Collection == ReadingItemCollectionFilter.Discover && Item.IsInUserLibrary)
        {
            return "Saved";
        }

        if (Item.Collection == ReadingItemCollectionFilter.Discover)
        {
            return Item.NewsStatus switch
            {
                NewsArticleStatus.New => null,
                NewsArticleStatus.ExtractionSucceeded => "Ready",
                NewsArticleStatus.ExtractionFailed => "Failed",
                _ => Item.NewsStatus?.ToString()
            };
        }

        return Item.ReadingStatus == ReadingItemReadingStatus.Completed ? "Completed" : null;
    }

    private string GetStatusTone()
    {
        if (Item.Collection == ReadingItemCollectionFilter.Discover && Item.IsInUserLibrary)
        {
            return "success";
        }

        if (Item.Collection == ReadingItemCollectionFilter.Discover)
        {
            return Item.NewsStatus switch
            {
                NewsArticleStatus.ExtractionSucceeded => "info",
                NewsArticleStatus.ExtractionFailed => "error",
                NewsArticleStatus.Ignored => "warning",
                _ => "default"
            };
        }

        return Item.ReadingStatus == ReadingItemReadingStatus.Completed ? "success" : "default";
    }

    private IReadOnlyList<AppMenuItem> MenuItems
    {
        get
        {
            var items = new List<AppMenuItem>();

            if (Item.CanPublish || Item.CanUnpublish)
            {
                items.Add(new AppMenuItem("visibility", Item.CanUnpublish ? "Unpublish" : "Publish", "public"));
            }

            if (Item.CanOpenOriginal)
            {
                items.Add(new AppMenuItem("original", "Open original", "open_in_new"));
            }

            if (Item.CanDelete)
            {
                items.Add(new AppMenuItem("delete", "Delete", "delete", Variant: "destructive"));
            }

            return items;
        }
    }

    private string GetDetails()
    {
        var details = new List<string>();

        if (!string.IsNullOrWhiteSpace(Item.Author))
        {
            details.Add(Item.Author);
        }

        if (!string.IsNullOrWhiteSpace(Item.OriginalLanguage))
        {
            details.Add(Item.OriginalLanguage);
        }

        return string.Join(" • ", details);
    }

    private string? GetPrimaryActionLabel()
    {
        if (Item.CanImport)
        {
            return Busy ? "Saving..." : "Save and open";
        }

        if (Item.CanContinue)
        {
            return "Continue";
        }

        return Item.CanOpen ? "Open" : null;
    }

    private string GetPrimaryActionVariant()
    {
        return Item.CanContinue || Item.CanImport ? "primary" : "secondary";
    }

    private string GetPrimaryActionIcon()
    {
        if (Item.CanImport)
        {
            return "download";
        }

        return Item.CanContinue ? "auto_stories" : "menu_book";
    }

    private Task HandleMenuActionAsync(string key)
    {
        return key switch
        {
            "visibility" => VisibilityToggleSelected.InvokeAsync(Item),
            "delete" => DeleteSelected.InvokeAsync(Item),
            "original" => OpenOriginalSelected.InvokeAsync(Item),
            _ => Task.CompletedTask
        };
    }
}
