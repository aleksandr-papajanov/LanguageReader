@using LanguageReader.Client.Features.ReadingItems.Services

@if (!string.IsNullOrWhiteSpace(logoPath))
{
    <AppImage Src="@logoPath"
              Alt="@displayName"
              Decorative="true"
              Inline="true"
              Fit="contain"
              Style="@WrapperStyle"
              MediaStyle="@MediaStyle"
              AdditionalClass="reading-item-source-mark"
              ImageClass="reading-item-source-mark__image" />
}

@code {
    [Parameter]
    public string? SourceKey { get; set; }

    [Parameter]
    public string? SourceName { get; set; }

    [Parameter]
    public string Size { get; set; } = "md";

    private string? displayName;
    private string? logoPath;

    private string WrapperStyle =>
        $"background: transparent; height: {ResolvedHeight}; width: auto; max-width: 100%;";

    private string MediaStyle =>
        "height: 100%; width: auto; max-width: 100%; object-fit: contain;";

    private string ResolvedHeight => Size switch
    {
        "sm" => "1rem",
        "md" => "6rem",
        "lg" => "10rem",
        _ => "3.1rem"
    };

    protected override void OnParametersSet()
    {
        var source = ReadingItemSourceCatalog.Find(SourceKey);
        displayName = !string.IsNullOrWhiteSpace(SourceName)
            ? SourceName
            : source?.DisplayName;
        logoPath = source?.LogoAssetPath;
    }
}
