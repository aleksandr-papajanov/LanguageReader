@using LanguageReader.Client.Features.ReadingItems.Services

@if (!string.IsNullOrWhiteSpace(LogoPath))
{
    <span class="@CssClass" title="@DisplayName" aria-label="@DisplayName">
        <AppImage Src="@LogoPath"
                  Alt="@DisplayName"
                  Decorative="true"
                  UseMask="true"
                  MaskColor="currentColor"
                  FillContainer="true"
                  Fit="contain"
                  AdditionalClass="reading-item-source-mark__logo" />
    </span>
}
else if (!string.IsNullOrWhiteSpace(DisplayName))
{
    <span class="@CssClass">@DisplayName</span>
}

@code {
    [Parameter]
    public string? SourceKey { get; set; }

    [Parameter]
    public string? SourceName { get; set; }

    [Parameter]
    public string Size { get; set; } = "md";

    private string? LogoPath => NormalizeSourceKey() switch
    {
        "svt" => "/assets/svt.svg",
        "aftonbladet" => "/assets/aftonbladet.svg",
        "sverigesradio" => "/assets/sveriges-radio.svg",
        "8sidor" => "/assets/8-sidor.svg",
        _ => null
    };

    private string DisplayName => NormalizeSourceKey() switch
    {
        "svt" => "SVT",
        "aftonbladet" => "Aftonbladet",
        "sverigesradio" => "Sveriges Radio",
        "8sidor" => "8 sidor",
        _ => SourceName ?? SourceKey ?? "Source"
    };

    private string? NormalizeSourceKey()
    {
        var value = SourceKey ?? SourceName;
        return value?.Trim().ToLowerInvariant().Replace(" ", string.Empty);
    }

    private string CssClass =>
        $"reading-item-source-mark reading-item-source-mark--{Size.ToLowerInvariant()}";
}
