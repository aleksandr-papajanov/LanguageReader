@using LanguageReader.Client.Features.ReadingItems.Services

@if (!string.IsNullOrWhiteSpace(displayName))
{
    <AppBadge Tone="@Tone"
              PreserveCase="true"
              Href="@Href"
              Title="@Title">@displayName</AppBadge>
}

@code {
    [Parameter]
    public string? SourceKey { get; set; }

    [Parameter]
    public string? SourceName { get; set; }

    [Parameter]
    public string Tone { get; set; } = "warning";

    [Parameter]
    public string? Href { get; set; }

    [Parameter]
    public string? Title { get; set; }

    private string? displayName;

    protected override void OnParametersSet()
    {
        var source = ReadingItemSourceCatalog.Find(SourceKey);
        displayName = !string.IsNullOrWhiteSpace(SourceName)
            ? SourceName
            : source?.DisplayName;
    }
}
