@inject SettingsApiClient Api
@inject UserSession Session

<AppHeading Title="Settings"
            Subtitle="Reader and translation preferences." />

@if (!Session.IsSignedIn)
{
    <SignInPrompt />
}
else if (state.IsLoading)
{
    <AppLoader Label="Loading settings" />
}
else
{
    <section class="settings-shell">
        <AppTabs Items="Tabs"
                 ActiveValue="@activeTab"
                 ActiveValueChanged="SelectTab"
                 AriaLabel="Settings sections" />
                 
        @if (activeTab == SettingsTab)
        {
            <AppPanel AdditionalClass="form-panel settings-panel">
                <LanguageSelect Id="language"
                                Label="Native Language"
                                Value="@state.NativeLanguage"
                                ValueChanged="@state.OnNativeLanguageChanged" />

                <AppSelect TValue="AiServiceMode"
                           Id="ai-mode"
                           Label="AI Mode"
                           Value="@state.AiServiceMode"
                           ValueChanged="@state.OnAiServiceModeChanged"
                           Options="@SettingsEditorState.AiModeOptions" />

                @if (!string.IsNullOrWhiteSpace(state.Message))
                {
                    <p class="app-inline-success">@state.Message</p>
                }

                @if (!string.IsNullOrWhiteSpace(state.Error))
                {
                    <p class="app-inline-error">@state.Error</p>
                }

                <AppButton Label="Save"
                           Variant="primary"
                           Icon="save"
                           OnClick="SaveAsync" />
            </AppPanel>
        }
        else if (activeTab == StatisticsTab)
        {
            <StatsView ShowHeading="false" />
        }
    </section>
}

@code {
    private const string SettingsTab = "settings";
    private const string StatisticsTab = "statistics";

    private static readonly IReadOnlyList<AppTabItem> Tabs =
    [
        new(SettingsTab, "Settings", "tune"),
        new(StatisticsTab, "Statistics", "monitoring")
    ];

    private readonly SettingsEditorState state = new();
    private string activeTab = SettingsTab;

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsSignedIn)
        {
            return;
        }

        await state.LoadAsync(Api, Session.Username!);
    }


    private async Task SaveAsync(MouseEventArgs _)
    {
        await state.SaveAsync(Api, Session.Username!);
    }

    private Task SelectTab(string tab)
    {
        activeTab = tab;
        return Task.CompletedTask;
    }
}
