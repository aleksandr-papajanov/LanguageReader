@inject NavigationManager Navigation

@if (Entries.Count == 0)
{
    <p>No saved words yet.</p>
}
else
{
    <div class="vocabulary-entry-list">
        @foreach (var entry in Entries)
        {
            <article class="@GetEntryCardClass(entry)">
                <div class="vocabulary-entry-card__main"
                     @onclick="@(() => OpenEntry(entry))">

                    <div class="vocabulary-entry-card__meta-row">
                        <AppBadge PreserveCase="true"
                                  Compact="true"
                                  Title="@entry.ReadingItemTitle">@entry.ReadingItemTitle</AppBadge>
                    </div>

                    <strong class="vocabulary-entry-card__text">
                        @entry.Word
                    </strong>

                    <p class="vocabulary-entry-card__translation">
                        @entry.Translation
                    </p>

                    @if (!string.IsNullOrWhiteSpace(entry.WordDetails?.Description))
                    {
                        <p class="vocabulary-entry-card__description">
                            @entry.WordDetails.Description
                        </p>
                    }
                </div>

                <div class="vocabulary-entry-card__actions">
                    <AppDateMeta Label="Saved"
                                 Value="@entry.CreatedAtUtc"
                                 Format="ddd, d MMM" />

                    @if (DeleteSelected.HasDelegate)
                    {
                        <AppDropdownMenu ButtonIcon="more_horiz"
                                         ButtonIconOnly="true"
                                         ButtonTitle="Word actions"
                                         ButtonVariant="ghost"
                                         ButtonSize="sm"
                                         Align="end"
                                         Disabled="@(BusyEntryId == entry.Id)"
                                         Items="@DeleteMenuItems"
                                         ItemSelected="@(_ => DeleteSelected.InvokeAsync(entry))" />
                    }
                </div>
            </article>
        }
    </div>
}

@code {
    [Parameter]
    public IReadOnlyList<VocabularyEntryDto> Entries { get; set; } = [];

    [Parameter]
    public Guid? BusyEntryId { get; set; }

    [Parameter]
    public EventCallback<VocabularyEntryDto> DeleteSelected { get; set; }

    private static readonly IReadOnlyList<AppMenuItem> DeleteMenuItems =
    [
        new("remove", "Remove from vocabulary", "bookmark_remove", Variant: "destructive")
    ];

    private Task OpenEntry(VocabularyEntryDto entry)
    {
        Navigation.NavigateTo($"/words/{entry.Id}");
        return Task.CompletedTask;
    }

    private static string GetEntryCardClass(VocabularyEntryDto entry)
    {
        return entry.Kind == SavedTextKind.LexicalUnit
            ? "vocabulary-entry-card"
            : "vocabulary-entry-card vocabulary-entry-card--fragment";
    }
}
