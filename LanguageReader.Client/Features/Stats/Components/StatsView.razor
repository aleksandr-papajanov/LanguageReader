@inject StatsApiClient Api
@inject UserSession Session
@inject AppErrorService Errors

@if (ShowHeading)
{
    <AppHeading Title="Statistics"
                Subtitle="AI operation usage across translation and vocabulary workflows." />
}

@if (!Session.IsSignedIn)
{
    <SignInPrompt />
}
else
{
    <AppPanel AdditionalClass="stats-filter-panel">
        <AppTextInput Id="stats-from"
                      Label="From"
                      Type="date"
                      Value="@fromDate"
                      ValueChanged="OnFromDateChanged"
                      LeadingIcon="calendar_month" />

        <AppTextInput Id="stats-to"
                      Label="To"
                      Type="date"
                      Value="@toDate"
                      ValueChanged="OnToDateChanged"
                      LeadingIcon="event" />

        <AppButton Label="Apply"
                   Variant="primary"
                   Icon="filter_alt"
                   Disabled="@isLoading"
                   IsLoading="@isLoading"
                   OnClick="@(_ => LoadStatsAsync())" />

        <AppButton Label="Reset"
                   Variant="ghost"
                   Icon="restart_alt"
                   Disabled="@isLoading"
                   OnClick="@(_ => ResetAsync())" />
    </AppPanel>

    @if (isLoading && stats is null)
    {
        <AppLoader Label="Loading AI operations" />
    }
    else if (stats is not null)
    {
        <div class="stats-content">
            <AppAiUsagePanel Title="AI Operations"
                             Summary="stats.Summary"
                             Operations="stats.Operations" />

            <AppSection Title="Operation Log"
                        Subtitle="Newest operations in the selected range.">
                <ChildContent>
                    @if (stats.Operations.Count == 0)
                    {
                        <p class="stats-empty">No AI operations found for this range.</p>
                    }
                    else
                    {
                        <div class="stats-operation-list">
                            @foreach (var operation in VisibleOperations)
                            {
                                <article class="stats-operation">
                                    <div class="stats-operation__main">
                                        <AppBadge PreserveCase="true">@operation.OperationName</AppBadge>
                                        <strong class="stats-operation__model">@operation.Provider / @operation.Model</strong>
                                        <span class="stats-operation__execution">@FormatExecution(operation)</span>
                                        <span class="stats-operation__date">@operation.CreatedAtUtc.LocalDateTime.ToString("MMM d, yyyy 'at' h:mm tt")</span>
                                    </div>

                                    <div class="stats-operation__numbers">
                                        <span>@operation.InputTokens in</span>
                                        <span>@operation.OutputTokens out</span>
                                        <strong>$@operation.TotalCostUsd.ToString("0.000000")</strong>
                                    </div>
                                </article>
                            }
                        </div>

                        <AppInfiniteScrollSentinel IsEnabled="@HasMoreOperations"
                                                   Reached="LoadMoreOperationsAsync" />
                    }
                </ChildContent>
            </AppSection>
        </div>
    }
}

@code {
    private const int OperationBatchSize = 12;

    [Parameter]
    public bool ShowHeading { get; set; } = true;

    private GetAiOperationsStatsResponse? stats;
    private string fromDate = DateTime.Today.AddDays(-7).ToString("yyyy-MM-dd");
    private string toDate = DateTime.Today.ToString("yyyy-MM-dd");
    private bool isLoading;
    private int renderedOperationCount;

    private IReadOnlyList<AiOperationDto> VisibleOperations =>
        stats?.Operations.Take(renderedOperationCount).ToList() ?? [];

    private bool HasMoreOperations =>
        stats is not null && renderedOperationCount < stats.Operations.Count;

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsSignedIn)
        {
            return;
        }

        await LoadStatsAsync();
    }

    private Task OnFromDateChanged(string value)
    {
        fromDate = value;
        return Task.CompletedTask;
    }

    private Task OnToDateChanged(string value)
    {
        toDate = value;
        return Task.CompletedTask;
    }

    private async Task ResetAsync()
    {
        fromDate = DateTime.Today.AddDays(-7).ToString("yyyy-MM-dd");
        toDate = DateTime.Today.ToString("yyyy-MM-dd");
        await LoadStatsAsync();
    }

    private async Task LoadStatsAsync()
    {
        if (!Session.IsSignedIn)
        {
            return;
        }

        isLoading = true;

        try
        {
            stats = await Api.GetAiOperationsStatsAsync(
                new GetAiOperationsStatsRequest(
                    Session.Username!,
                    ParseStartDate(fromDate),
                    ParseEndDate(toDate)));
            renderedOperationCount = Math.Min(OperationBatchSize, stats.Operations.Count);
        }
        catch (Exception exception)
        {
            Errors.Show(exception);
            renderedOperationCount = 0;
        }
        finally
        {
            isLoading = false;
        }
    }

    private Task LoadMoreOperationsAsync()
    {
        if (stats is null)
        {
            return Task.CompletedTask;
        }

        renderedOperationCount = Math.Min(
            renderedOperationCount + OperationBatchSize,
            stats.Operations.Count);

        return InvokeAsync(StateHasChanged);
    }

    private static DateTimeOffset? ParseStartDate(string value)
    {
        return DateTime.TryParse(value, out var date)
            ? new DateTimeOffset(date.Date, TimeZoneInfo.Local.GetUtcOffset(date.Date)).ToUniversalTime()
            : null;
    }

    private static DateTimeOffset? ParseEndDate(string value)
    {
        return DateTime.TryParse(value, out var date)
            ? new DateTimeOffset(date.Date.AddDays(1), TimeZoneInfo.Local.GetUtcOffset(date.Date.AddDays(1))).ToUniversalTime()
            : null;
    }

    private static string FormatExecution(AiOperationDto operation)
    {
        var turns = operation.TurnCount == 1 ? "1 turn" : $"{operation.TurnCount} turns";

        if (operation.ToolCallCount <= 0)
        {
            return $"{operation.ExecutionMode} · {turns}";
        }

        var tools = string.IsNullOrWhiteSpace(operation.ToolNames)
            ? "tools"
            : operation.ToolNames;

        return $"{operation.ExecutionMode} · {turns} · {operation.ToolCallCount} tool call(s): {tools}";
    }
}
