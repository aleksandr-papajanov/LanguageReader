@inject IJSRuntime JsRuntime
@implements IAsyncDisposable

<article class="@ReaderPageClass"
         @ref="readerPage"
         @onclick="HandleReaderClickAsync"
         @onclick:stopPropagation="true">
    <div class="reader-range-layer" aria-hidden="true">
        @foreach (var rect in overlayRects)
        {
            <span class="@GetFillClass(rect)"
                  style="@GetOverlayStyle(rect)"></span>
        }

        @foreach (var frame in overlayRects)
        {
            <span class="@GetFrameClass(frame)"
                  style="@GetOverlayStyle(frame)"></span>
        }
    </div>

    <div class="reader-fragment-action-layer" aria-label="Translated fragment actions">
        <AppButton Variant="ghost"
                   Size="sm"
                   Icon="ink_highlighter"
                   IconSize="15"
                   IconOnly="true"
                   AdditionalClass="reader-fragment-action reader-fragment-action--select reader-fragment-action--measure"
                   Disabled="true"
                   StopPropagation="true"
                   Title="Measure translated fragment action" />

        <div class="reader-floating-measurements" aria-hidden="true">
            <ReaderSelectionActions AdditionalClass="reader-selection-actions--measure"
                                    ActiveMode="@SelectionKind.Word"
                                    IsTranslateDisabled="@false"
                                    IsTranslateLoading="@false" />

            <ReaderTranslatedFragmentActions Translation="@MeasurementTranslation"
                                             AdditionalClass="reader-fragment-actions--measure"
                                             Mode="ReaderTranslatedFragmentActions.ReaderFragmentActionMode.Popup"
                                             IsActive="@false"
                                             IsInVocabulary="@true"
                                             IsBusy="@false" />
        </div>

        @if (BuildSelectionActionAnchor() is { } selectionAnchor)
        {
            <ReaderSelectionActions Style="@GetActionAnchorStyle(selectionAnchor)"
                                    ActiveMode="@(Selection?.SelectionType ?? ActiveMode)"
                                    IsTranslateDisabled="@IsSelectionTranslateDisabled"
                                    IsTranslateLoading="@IsTranslationLoading"
                                    ModeSelected="SelectionModeSelected"
                                    TranslateClicked="SelectionTranslateSelected" />
        }

        @if (BuildActiveTranslationPopupAnchor() is { } popupAnchor)
        {
            <ReaderTranslatedFragmentActions Translation="popupAnchor.Translation!"
                                             Style="@GetActionAnchorStyle(popupAnchor)"
                                             Mode="ReaderTranslatedFragmentActions.ReaderFragmentActionMode.Popup"
                                             IsActive="true"
                                             IsInVocabulary="@IsInVocabulary(popupAnchor.Translation!)"
                                             IsBusy="@IsTranslationActionBusy(popupAnchor.Translation!)"
                                             IsDisplayLoading="@IsTranslationActionLoading(popupAnchor.Translation!, TranslationActionKind.Display)"
                                             IsVocabularyLoading="@IsTranslationActionLoading(popupAnchor.Translation!, TranslationActionKind.Vocabulary)"
                                             IsDeleteLoading="@IsTranslationActionLoading(popupAnchor.Translation!, TranslationActionKind.Delete)"
                                             SelectClicked="TranslationSelected"
                                             DisplayToggleClicked="TranslationDisplayToggleSelected"
                                             VocabularyToggleClicked="TranslationVocabularyToggleSelected"
                                             OpenDetailsClicked="TranslationOpenDetailsSelected"
                                             DeleteClicked="TranslationDeleteSelected" />
        }

        @foreach (var markerAnchor in BuildTranslationMarkerAnchors())
        {
            <ReaderTranslatedFragmentActions Translation="markerAnchor.Translation!"
                                             Style="@GetActionAnchorStyle(markerAnchor)"
                                             Mode="ReaderTranslatedFragmentActions.ReaderFragmentActionMode.SelectMarker"
                                             IsActive="@(ActiveTranslation?.Id == markerAnchor.Translation!.Id)"
                                             IsInVocabulary="@IsInVocabulary(markerAnchor.Translation!)"
                                             IsBusy="@IsTranslationActionBusy(markerAnchor.Translation!)"
                                             SelectClicked="TranslationSelected"
                                             UnselectClicked="TranslationUnselected"
                                             DisplayToggleClicked="TranslationDisplayToggleSelected"
                                             VocabularyToggleClicked="TranslationVocabularyToggleSelected"
                                             OpenDetailsClicked="TranslationOpenDetailsSelected"
                                             DeleteClicked="TranslationDeleteSelected" />
        }
    </div>

    @foreach (var paragraph in Blocks)
    {
        @if (paragraph.Type == ReadingContentBlockType.Image)
        {
            <figure class="reader-page__image">
                @if (TryGetImageSource(paragraph.ImageId, out var imageSource))
                {
                    <AppImage Src="@imageSource"
                              Alt="Embedded reading item image"
                              Fit="contain"
                              AspectRatio="4 / 3"
                              AdditionalClass="reader-page__embedded-image" />
                }
            </figure>
        }
        else if (paragraph.Index < 0)
        {
            <div class="reader-page__spacer" aria-hidden="true"></div>
        }
        else
        {
            <p data-block-index="@paragraph.Index">
                @foreach (var chunk in BuildTextChunks(paragraph))
                {
                    @if (!string.IsNullOrEmpty(chunk.Text))
                    {
                        <span class="@GetChunkClass(chunk)"
                              style="@GetChunkStyle(chunk)"
                              data-original-start="@chunk.StartOffset"
                              data-original-end="@chunk.EndOffset"
                              data-original-text="@chunk.OriginalText"
                              data-translated="@chunk.IsTranslated.ToString().ToLowerInvariant()">@chunk.Text</span>
                    }
                }
            </p>
        }
    }

    <span class="reader-page__end" data-reader-page-end="true"></span>
</article>

@code {
    private static readonly TranslatedRangeDto MeasurementTranslation = new(
        Guid.Empty,
        string.Empty,
        Guid.Empty,
        0,
        0,
        1,
        string.Empty,
        string.Empty,
        null,
        false,
        SavedTextKind.LexicalUnit,
        DateTimeOffset.UnixEpoch);

    private readonly List<ReaderRangeRect> overlayRects = [];

    private ElementReference readerPage;
    private DotNetObjectReference<ReaderTextSurface>? dotNetReference;
    private string? resizeObserverId;
    private string? scrollObserverId;
    private string? selectionObserverId;
    private bool shouldMeasure;
    private ReaderFloatingMeasurements? floatingMeasurements;
    private string overlaySignature = string.Empty;
    private long lastScrollRequestKey = -1;

    [Parameter]
    public IReadOnlyList<ReaderBlock> Blocks { get; set; } = [];

    [Parameter]
    public IReadOnlyDictionary<string, ReadingImageDto> Images { get; set; } = new Dictionary<string, ReadingImageDto>();

    [Parameter]
    public IReadOnlyList<TranslatedRangeDto> TranslatedRanges { get; set; } = [];

    [Parameter]
    public IReadOnlyList<VocabularyEntryDto> VocabularyEntries { get; set; } = [];

    [Parameter]
    public ReaderSelection? Selection { get; set; }

    [Parameter]
    public TranslatedRangeDto? ActiveTranslation { get; set; }

    [Parameter]
    public SelectionKind ActiveMode { get; set; } = SelectionKind.Word;

    [Parameter]
    public bool IsTranslationLoading { get; set; }

    [Parameter]
    public bool IsSelectionTranslateDisabled { get; set; }

    [Parameter]
    public Guid? LoadingTranslationId { get; set; }

    [Parameter]
    public string? LoadingTranslationAction { get; set; }

    [Parameter]
    public EventCallback<ReaderOffsetTap> OffsetSelected { get; set; }

    [Parameter]
    public EventCallback<ReaderCustomSelectionRange> CustomRangeSelected { get; set; }

    [Parameter]
    public EventCallback<int> VisibleBlockChanged { get; set; }

    [Parameter]
    public EventCallback<TranslatedRangeDto> TranslationSelected { get; set; }

    [Parameter]
    public EventCallback<TranslatedRangeDto> TranslationUnselected { get; set; }

    [Parameter]
    public EventCallback<TranslatedRangeDto> TranslationDisplayToggleSelected { get; set; }

    [Parameter]
    public EventCallback<TranslatedRangeDto> TranslationVocabularyToggleSelected { get; set; }

    [Parameter]
    public EventCallback<TranslatedRangeDto> TranslationOpenDetailsSelected { get; set; }

    [Parameter]
    public EventCallback<TranslatedRangeDto> TranslationDeleteSelected { get; set; }

    [Parameter]
    public EventCallback<SelectionKind> SelectionModeSelected { get; set; }

    [Parameter]
    public EventCallback SelectionTranslateSelected { get; set; }

    [Parameter]
    public EventCallback ClearSelectionRequested { get; set; }

    [Parameter]
    public int? ScrollBlockIndex { get; set; }

    [Parameter]
    public int? ScrollOffset { get; set; }

    [Parameter]
    public long ScrollRequestKey { get; set; }

    private ReaderSelection? previousSelection;

    private string ReaderPageClass =>
        $"reader-page{(floatingMeasurements is null ? " reader-page--measuring" : string.Empty)}";

    protected override void OnParametersSet()
    {
        var nextSignature = string.Join("|", BuildOverlays().Select(range =>
            $"{range.Id}:{range.Kind}:{range.Layer}:{range.BlockIndex}:{range.StartOffset}:{range.EndOffset}:{range.DisplayText}:{IsTranslationLoading}"));

        if (!string.Equals(nextSignature, overlaySignature, StringComparison.Ordinal))
        {
            overlaySignature = nextSignature;
            shouldMeasure = true;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            dotNetReference = DotNetObjectReference.Create(this);

            resizeObserverId = await JsRuntime.InvokeAsync<string>(
                "languageReaderSelection.observeRangeRoot",
                readerPage,
                dotNetReference);

            scrollObserverId = await JsRuntime.InvokeAsync<string>(
                "languageReaderSelection.observeReaderScroll",
                readerPage,
                dotNetReference);

            selectionObserverId = await JsRuntime.InvokeAsync<string>(
                "languageReaderSelection.observeNativeSelection",
                readerPage,
                dotNetReference);
        }

        if (floatingMeasurements is null)
        {
            floatingMeasurements = await JsRuntime.InvokeAsync<ReaderFloatingMeasurements>(
                "languageReaderSelection.measureFloatingPanels",
                readerPage);

            shouldMeasure = true;
            StateHasChanged();
            return;
        }

        if (ScrollBlockIndex.HasValue && ScrollRequestKey != lastScrollRequestKey)
        {
            lastScrollRequestKey = ScrollRequestKey;

            await JsRuntime.InvokeVoidAsync(
                "languageReaderSelection.scrollParagraphOffsetIntoViewIfNeeded",
                readerPage,
                ScrollBlockIndex.Value,
                ScrollOffset ?? 0);
        }

        if (Selection is not null && !IsSameSelection(Selection, previousSelection))
        {
            previousSelection = Selection;

            await JsRuntime.InvokeVoidAsync(
                "languageReaderSelection.scrollRangeStartIntoViewIfNeeded",
                readerPage,
                Selection.BlockIndex,
                Selection.StartOffset);
        }

        if (!shouldMeasure && !firstRender)
        {
            return;
        }

        shouldMeasure = false;
        await MeasureOverlaysAsync();
    }

    private static bool IsSameSelection(ReaderSelection? current, ReaderSelection? previous)
    {
        return current?.BlockIndex == previous?.BlockIndex
            && current?.StartOffset == previous?.StartOffset
            && current?.EndOffset == previous?.EndOffset
            && current?.SelectionType == previous?.SelectionType;
    }

    [JSInvokable]
    public async Task RequestRangeMeasureAsync()
    {
        await MeasureOverlaysAsync();
    }

    [JSInvokable]
    public async Task NotifyVisibleBlockChangedAsync(int blockIndex)
    {
        await VisibleBlockChanged.InvokeAsync(blockIndex);
    }

    [JSInvokable]
    public async Task NotifyNativeSelectionChangedAsync(
        int BlockIndex,
        int startOffset,
        int endOffset,
        string selectedText)
    {
        if (string.IsNullOrWhiteSpace(selectedText))
        {
            return;
        }

        var selectedRange = new ReaderCustomSelectionRange(
            BlockIndex,
            startOffset,
            endOffset,
            selectedText);

        if (ShouldIgnoreCustomSelection(selectedRange))
        {
            await IgnoreCustomSelectionAsync();
            return;
        }

        await CustomRangeSelected.InvokeAsync(selectedRange);

        await JsRuntime.InvokeVoidAsync("languageReaderSelection.clearSelectedText");
    }

    [JSInvokable]
    public async Task NotifyNativeSelectionRejectedAsync()
    {
        await IgnoreCustomSelectionAsync();
    }

    public async Task<ReadingPositionDto?> GetViewportPositionAsync(Guid readingItemId)
    {
        var visibleBlockIndex = await JsRuntime.InvokeAsync<int?>(
            "languageReaderSelection.getReaderProgressBlockIndex",
            readerPage);

        return visibleBlockIndex.HasValue
            ? new ReadingPositionDto(readingItemId, visibleBlockIndex.Value, 0)
            : null;
    }

    private async Task HandleReaderClickAsync(MouseEventArgs args)
    {
        var selectedRange = await JsRuntime.InvokeAsync<ReaderCustomSelectionRange?>(
            "languageReaderSelection.getSelectedRange",
            readerPage);

        if (selectedRange is not null && !string.IsNullOrWhiteSpace(selectedRange.SelectedText))
        {
            if (ShouldIgnoreCustomSelection(selectedRange))
            {
                await IgnoreCustomSelectionAsync();
                return;
            }

            await CustomRangeSelected.InvokeAsync(selectedRange);
            await JsRuntime.InvokeVoidAsync("languageReaderSelection.clearSelectedText");
            return;
        }

        var hit = await JsRuntime.InvokeAsync<ReaderDomTextHit?>(
            "languageReaderSelection.getTextOffsetAtPoint",
            readerPage,
            args.ClientX,
            args.ClientY);

        if (hit is null)
        {
            if (Selection is not null || ActiveTranslation is not null)
            {
                await ClearSelectionRequested.InvokeAsync();
            }

            return;
        }

        var paragraph = Blocks.FirstOrDefault(item => item.Index == hit.BlockIndex);
        if (paragraph is null)
        {
            return;
        }

        await OffsetSelected.InvokeAsync(new ReaderOffsetTap(paragraph, hit.Offset));
    }

    private async Task MeasureOverlaysAsync()
    {
        var ranges = BuildOverlays().ToList();

        if (ranges.Count == 0)
        {
            overlayRects.Clear();
            StateHasChanged();
            return;
        }

        var measured = await JsRuntime.InvokeAsync<ReaderRangeRect[]>(
            "languageReaderSelection.measureRanges",
            readerPage,
            ranges);

        overlayRects.Clear();
        overlayRects.AddRange(measured);
        StateHasChanged();
    }

    private bool ShouldIgnoreCustomSelection(ReaderCustomSelectionRange selectedRange)
    {
        return TranslatedRanges.Any(range =>
            range.BlockIndex == selectedRange.BlockIndex
            && RangesOverlap(range.StartOffset, range.EndOffset, selectedRange.StartOffset, selectedRange.EndOffset)
            && string.Equals(
                NormalizeSelectionText(range.OriginalText),
                NormalizeSelectionText(selectedRange.SelectedText),
                StringComparison.Ordinal));
    }

    private static bool RangesOverlap(int firstStart, int firstEnd, int secondStart, int secondEnd)
    {
        return firstStart < secondEnd && secondStart < firstEnd;
    }

    private static string NormalizeSelectionText(string value)
    {
        return string.Join(
            " ",
            value.Split((char[]?)null, StringSplitOptions.RemoveEmptyEntries));
    }

    private async Task IgnoreCustomSelectionAsync()
    {
        if (Selection is not null || ActiveTranslation is not null)
        {
            await ClearSelectionRequested.InvokeAsync();
        }

        await JsRuntime.InvokeVoidAsync("languageReaderSelection.clearSelectedText");
    }

    private IEnumerable<ReaderRangeOverlay> BuildOverlays()
    {
        foreach (var range in GetVisibleTranslations().OrderBy(GetTranslationLayerPriority).ThenBy(item => item.StartOffset))
        {
            foreach (var overlay in BuildTranslationOverlays(range))
            {
                yield return overlay;
            }
        }

        if (Selection is not null && ActiveTranslation is null)
        {
            foreach (var overlay in BuildSelectionOverlays(Selection))
            {
                yield return overlay;
            }
        }

        if (ActiveTranslation is not null)
        {
            foreach (var overlay in BuildTranslationOverlays(ActiveTranslation, "active-translation"))
            {
                yield return overlay;
            }
        }
    }

    private IEnumerable<ReaderRangeOverlay> BuildSelectionOverlays(ReaderSelection readerSelection)
    {
        yield return new ReaderRangeOverlay(
            "selection",
            IsTranslationLoading ? "selection-loading" : "selection",
            "selection",
            readerSelection.BlockIndex,
            readerSelection.StartOffset,
            readerSelection.EndOffset,
            null);
    }

    private IEnumerable<ReaderRangeOverlay> BuildTranslationOverlays(
        TranslatedRangeDto range,
        string kind = "translation")
    {
        var layer = IsInVocabulary(range) ? "vocabulary" : "translation";
        var displayText = range.ShowOriginal ? null : range.TranslatedText;

        yield return new ReaderRangeOverlay(
            $"{kind}-{range.Id}",
            kind,
            layer,
            range.BlockIndex,
            range.StartOffset,
            range.EndOffset,
            displayText);
    }

    private IReadOnlyList<ReaderTextChunk> BuildTextChunks(ReaderBlock paragraph)
    {
        var translations = GetVisibleTranslations()
            .Where(range =>
                range.BlockIndex == paragraph.Index)
            .ToList();

        return BuildTextChunks(paragraph, translations, 0, paragraph.Text.Length, null);
    }

    private IReadOnlyList<ReaderTextChunk> BuildTextChunks(
        ReaderBlock paragraph,
        IReadOnlyList<TranslatedRangeDto> translations,
        int rangeStart,
        int rangeEnd,
        TranslatedRangeDto? owner)
    {
        var chunks = new List<ReaderTextChunk>();
        var cursor = rangeStart;
        var replacements = GetDirectChildTranslations(translations, rangeStart, rangeEnd, owner);

        foreach (var replacement in replacements)
        {
            if (replacement.StartOffset < cursor || replacement.StartOffset >= paragraph.Text.Length)
            {
                continue;
            }

            var endOffset = Math.Clamp(replacement.EndOffset, replacement.StartOffset, paragraph.Text.Length);
            if (endOffset <= replacement.StartOffset)
            {
                continue;
            }

            if (replacement.StartOffset > cursor)
            {
                chunks.Add(new ReaderTextChunk(
                    paragraph.Text[cursor..replacement.StartOffset],
                    paragraph.Text[cursor..replacement.StartOffset],
                    cursor,
                    replacement.StartOffset,
                    false,
                    owner));
            }

            if (replacement.ShowOriginal)
            {
                chunks.AddRange(BuildTextChunks(paragraph, translations, replacement.StartOffset, endOffset, replacement));
                cursor = endOffset;
                continue;
            }

            chunks.Add(new ReaderTextChunk(
                replacement.TranslatedText,
                paragraph.Text[replacement.StartOffset..endOffset],
                replacement.StartOffset,
                endOffset,
                true,
                replacement));

            cursor = endOffset;
        }

        if (cursor < rangeEnd)
        {
            chunks.Add(new ReaderTextChunk(
                paragraph.Text[cursor..rangeEnd],
                paragraph.Text[cursor..rangeEnd],
                cursor,
                rangeEnd,
                false,
                owner));
        }

        return chunks;
    }

    private IReadOnlyList<TranslatedRangeDto> GetDirectChildTranslations(
        IReadOnlyList<TranslatedRangeDto> translations,
        int rangeStart,
        int rangeEnd,
        TranslatedRangeDto? owner)
    {
        return translations
            .Where(candidate =>
                candidate.Id != owner?.Id
                && candidate.StartOffset >= rangeStart
                && candidate.EndOffset <= rangeEnd
                && !translations.Any(parent =>
                    parent.Id != candidate.Id
                    && parent.Id != owner?.Id
                    && parent.StartOffset >= rangeStart
                    && parent.EndOffset <= rangeEnd
                    && Contains(parent, candidate)))
            .OrderBy(candidate => candidate.StartOffset)
            .ThenBy(candidate => GetTranslationLayerPriority(candidate))
            .ThenByDescending(candidate => candidate.EndOffset)
            .ToList();
    }

    private IEnumerable<TranslatedRangeDto> GetVisibleTranslations()
    {
        return TranslatedRanges.Where(range =>
            !TranslatedRanges.Any(parent =>
                parent.Id != range.Id
                && !parent.ShowOriginal
                && Contains(parent, range)));
    }

    private static bool Contains(TranslatedRangeDto parent, TranslatedRangeDto child)
    {
        return parent.ReadingItemId == child.ReadingItemId
            && parent.BlockIndex == child.BlockIndex
            && parent.StartOffset <= child.StartOffset
            && parent.EndOffset >= child.EndOffset
            && (parent.StartOffset < child.StartOffset || parent.EndOffset > child.EndOffset);
    }

    private TranslationActionAnchor? BuildActiveTranslationPopupAnchor()
    {
        if (ActiveTranslation is null || floatingMeasurements is null)
        {
            return null;
        }

        var anchorRect = overlayRects
            .Where(rect =>
                rect.Id.StartsWith($"active-translation-{ActiveTranslation.Id}", StringComparison.Ordinal)
                || rect.Id.StartsWith($"translation-{ActiveTranslation.Id}", StringComparison.Ordinal))
            .OrderBy(rect => rect.Top)
            .ThenBy(rect => rect.Left)
            .FirstOrDefault();

        return anchorRect is null
            ? null
            : new TranslationActionAnchor(
                ActiveTranslation,
                anchorRect.Left,
                GetFloatingPanelTop(anchorRect, floatingMeasurements.TranslationPopupHeight),
                floatingMeasurements.TranslationPopupWidth);
    }

    private IEnumerable<TranslationActionAnchor> BuildTranslationMarkerAnchors()
    {
        foreach (var range in GetVisibleTranslations().OrderBy(GetTranslationLayerPriority).ThenBy(item => item.StartOffset))
        {
            var anchorRect = overlayRects
                .Where(rect =>
                    rect.Id.StartsWith($"translation-{range.Id}", StringComparison.Ordinal)
                    && rect.Kind == "translation")
                .OrderBy(rect => rect.Top)
                .ThenBy(rect => rect.Left)
                .FirstOrDefault();

            if (anchorRect is null)
            {
                continue;
            }

            if (floatingMeasurements is null)
            {
                continue;
            }

            yield return new TranslationActionAnchor(
                range,
                anchorRect.Left - floatingMeasurements.MarkerShift,
                anchorRect.Top + ((anchorRect.Height - floatingMeasurements.MarkerHeight) / 2),
                floatingMeasurements.MarkerShift);
        }
    }

    private TranslationActionAnchor? BuildSelectionActionAnchor()
    {
        if (Selection is null || ActiveTranslation is not null || floatingMeasurements is null)
        {
            return null;
        }

        var anchorRect = overlayRects
            .Where(rect => rect.Id.StartsWith("selection", StringComparison.Ordinal))
            .OrderBy(rect => rect.Top)
            .ThenBy(rect => rect.Left)
            .FirstOrDefault();

        return anchorRect is null
            ? null
            : new TranslationActionAnchor(
                null,
                anchorRect.Left,
                GetFloatingPanelTop(anchorRect, floatingMeasurements.SelectionActionsHeight),
                floatingMeasurements.SelectionActionsWidth);
    }

    private static double GetFloatingPanelTop(ReaderRangeRect anchorRect, double panelHeight)
    {
        var aboveTop = anchorRect.Top - panelHeight - 8;
        if (aboveTop >= 8)
        {
            return aboveTop;
        }

        return anchorRect.Top + anchorRect.Height + 8;
    }

    private bool IsInVocabulary(TranslatedRangeDto range)
    {
        if (range.VocabularyEntryId.HasValue)
        {
            return VocabularyEntries.Any(entry =>
                entry.IsVisibleInVocabulary
                && entry.Id == range.VocabularyEntryId.Value);
        }

        return VocabularyEntries.Any(entry =>
            entry.IsVisibleInVocabulary
            && entry.ReadingItemId == range.ReadingItemId
            && entry.Position?.BlockIndex == range.BlockIndex
            && entry.Position?.CharacterOffset == range.StartOffset
            && entry.Kind == range.Kind
            && string.Equals(entry.Word, range.OriginalText, StringComparison.OrdinalIgnoreCase));
    }

    private bool IsTranslationActionBusy(TranslatedRangeDto range)
    {
        return LoadingTranslationId == range.Id;
    }

    private bool IsTranslationActionLoading(TranslatedRangeDto range, string action)
    {
        return LoadingTranslationId == range.Id
            && string.Equals(LoadingTranslationAction, action, StringComparison.Ordinal);
    }

    private static int GetTranslationLayerPriority(TranslatedRangeDto range)
    {
        return range.Kind switch
        {
            SavedTextKind.Text => 3,
            SavedTextKind.LexicalUnit => 4,
            _ => 5
        };
    }

    private static string GetFillClass(ReaderRangeRect rect)
    {
        return $"reader-range-fill reader-range-fill--{rect.Kind} reader-range-fill--{rect.Layer}";
    }

    private static string GetFrameClass(ReaderRangeRect frame)
    {
        return $"reader-range-frame reader-range-frame--{frame.Kind} reader-range-frame--{frame.Layer}";
    }

    private static string GetOverlayStyle(ReaderRangeRect rect)
    {
        return string.Create(
            System.Globalization.CultureInfo.InvariantCulture,
            $"left:{rect.Left:0.###}px;top:{rect.Top:0.###}px;width:{rect.Width:0.###}px;height:{rect.Height:0.###}px;");
    }

    private static string? GetChunkClass(ReaderTextChunk chunk)
    {
        return chunk.SelectTranslation is null
            ? null
            : "reader-translated-fragment__text";
    }

    private string? GetChunkStyle(ReaderTextChunk chunk)
    {
        if (chunk.SelectTranslation is null)
        {
            return null;
        }

        if (floatingMeasurements is null)
        {
            return null;
        }

        return string.Create(
            System.Globalization.CultureInfo.InvariantCulture,
            $"--reader-translation-marker-shift:{floatingMeasurements.MarkerShift:0.###}px;");
    }

    private static string GetActionAnchorStyle(TranslationActionAnchor anchor)
    {
        return string.Create(
            System.Globalization.CultureInfo.InvariantCulture,
            $"left:clamp(0.75rem, {anchor.Left:0.###}px, calc(100% - {anchor.Width:0.###}px - 0.75rem));top:{anchor.Top:0.###}px;");
    }

    private bool TryGetImageSource(string? imageId, out string source)
    {
        source = string.Empty;

        if (string.IsNullOrWhiteSpace(imageId)
            || !Images.TryGetValue(imageId, out var image)
            || string.IsNullOrWhiteSpace(image.Base64Content)
            || string.IsNullOrWhiteSpace(image.ContentType))
        {
            return false;
        }

        source = $"data:{image.ContentType};base64,{image.Base64Content}";
        return true;
    }

    public async ValueTask DisposeAsync()
    {
        if (!string.IsNullOrWhiteSpace(scrollObserverId))
        {
            await JsRuntime.InvokeVoidAsync("languageReaderSelection.unobserveReaderScroll", scrollObserverId);
        }

        if (!string.IsNullOrWhiteSpace(resizeObserverId))
        {
            await JsRuntime.InvokeVoidAsync("languageReaderSelection.unobserveRangeRoot", resizeObserverId);
        }

        if (!string.IsNullOrWhiteSpace(selectionObserverId))
        {
            await JsRuntime.InvokeVoidAsync("languageReaderSelection.unobserveNativeSelection", selectionObserverId);
        }

        dotNetReference?.Dispose();
    }

    private sealed record ReaderTextChunk(
        string Text,
        string OriginalText,
        int StartOffset,
        int EndOffset,
        bool IsTranslated,
        TranslatedRangeDto? SelectTranslation);

    private sealed record TranslationActionAnchor(
        TranslatedRangeDto? Translation,
        double Left,
        double Top,
        double Width);

    private sealed record ReaderFloatingMeasurements(
        double MarkerShift,
        double MarkerHeight,
        double SelectionActionsWidth,
        double SelectionActionsHeight,
        double TranslationPopupWidth,
        double TranslationPopupHeight);

    private static class TranslationActionKind
    {
        public const string Display = "display";
        public const string Vocabulary = "vocabulary";
        public const string Delete = "delete";
    }
}
