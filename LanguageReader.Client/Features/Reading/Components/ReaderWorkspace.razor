@inject ReaderWorkspaceService Workspace
@implements IDisposable

@if (Workspace.CurrentReadingItemId.HasValue)
{
    <ReaderView ReadingItemId="Workspace.CurrentReadingItemId.Value"
                QueryBlock="Workspace.QueryBlock"
                QueryOffset="Workspace.QueryOffset"
                ActivationVersion="Workspace.ActivationVersion"
                OpenRequestVersion="Workspace.OpenRequestVersion"
                IsActive="@IsVisible" />
}

@code {
    private bool IsVisible => Workspace.Mode == ReaderWorkspaceMode.Reader;

    protected override void OnInitialized()
    {
        Workspace.Changed += HandleWorkspaceChanged;
    }

    private void HandleWorkspaceChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Workspace.Changed -= HandleWorkspaceChanged;
    }
}
