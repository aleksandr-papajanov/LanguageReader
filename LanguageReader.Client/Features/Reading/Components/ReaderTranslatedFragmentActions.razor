@if (Mode == ReaderFragmentActionMode.SelectMarker)
{
    <AppButton Variant="ghost"
               Size="sm"
               Icon="@(IsActive ? "close" : "ink_highlighter")"
               IconSize="15"
               IconOnly="true"
               AdditionalClass="@SelectActionClass"
               Style="@Style"
               Title="@(IsActive ? "Unselect translated fragment" : "Select translated fragment")"
               Disabled="@IsBusy"
               IsLoading="@IsBusy"
               StopPropagation="true"
               OnClick="@ToggleSelectionAsync" />
}
else
{
    <ReaderFloatingPanel Style="@Style" AdditionalClass="@CssClass">
        @if (IsInVocabulary)
        {
            <AppButton Variant="ghost"
                       Size="sm"
                       Icon="dictionary"
                       IconSize="15"
                       IconOnly="true"
                       AdditionalClass="reader-fragment-action reader-fragment-action--icon"
                       Title="Open vocabulary entry"
                       Disabled="@IsBusy"
                       StopPropagation="true"
                       OnClick="@(() => OpenDetailsClicked.InvokeAsync(Translation))" />
        }
        <AppButton Variant="ghost"
                   Size="sm"
                   Icon="visibility"
                   IconSize="15"
                   IconOnly="true"
                   AdditionalClass="reader-fragment-action reader-fragment-action--icon"
                   Title="Show original or translation"
                   Disabled="@IsBusy"
                   IsLoading="@IsDisplayLoading"
                   StopPropagation="true"
                   OnClick="@(() => DisplayToggleClicked.InvokeAsync(Translation))" />
        <AppButton Variant="ghost"
                   Size="sm"
                   Icon="@(IsInVocabulary ? "bookmark_remove" : "bookmark_add")"
                   IconSize="15"
                   IconOnly="true"
                   AdditionalClass="reader-fragment-action reader-fragment-action--icon"
                   Title="@(IsInVocabulary ? "Remove from vocabulary" : "Add to vocabulary")"
                   Disabled="@IsBusy"
                   IsLoading="@IsVocabularyLoading"
                   StopPropagation="true"
                   OnClick="@(() => VocabularyToggleClicked.InvokeAsync(Translation))" />
        <AppButton Variant="destructive"
                   Size="sm"
                   Icon="delete"
                   IconSize="15"
                   IconOnly="true"
                   AdditionalClass="reader-fragment-action reader-fragment-action--icon reader-fragment-action--danger"
                   Title="Delete translation"
                   Disabled="@IsBusy"
                   IsLoading="@IsDeleteLoading"
                   StopPropagation="true"
                   OnClick="@(() => DeleteClicked.InvokeAsync(Translation))" />
    </ReaderFloatingPanel>
}

@code {
    [Parameter, EditorRequired]
    public TranslatedRangeDto Translation { get; set; } = null!;

    [Parameter]
    public bool IsActive { get; set; }

    [Parameter]
    public bool IsInVocabulary { get; set; }

    [Parameter]
    public bool IsBusy { get; set; }

    [Parameter]
    public bool IsDisplayLoading { get; set; }

    [Parameter]
    public bool IsVocabularyLoading { get; set; }

    [Parameter]
    public bool IsDeleteLoading { get; set; }

    [Parameter]
    public string? Style { get; set; }

    [Parameter]
    public string? AdditionalClass { get; set; }

    [Parameter]
    public ReaderFragmentActionMode Mode { get; set; } = ReaderFragmentActionMode.SelectMarker;

    [Parameter]
    public EventCallback<TranslatedRangeDto> SelectClicked { get; set; }

    [Parameter]
    public EventCallback<TranslatedRangeDto> UnselectClicked { get; set; }

    [Parameter]
    public EventCallback<TranslatedRangeDto> DisplayToggleClicked { get; set; }

    [Parameter]
    public EventCallback<TranslatedRangeDto> VocabularyToggleClicked { get; set; }

    [Parameter]
    public EventCallback<TranslatedRangeDto> OpenDetailsClicked { get; set; }

    [Parameter]
    public EventCallback<TranslatedRangeDto> DeleteClicked { get; set; }

    private string CssClass =>
        $"reader-fragment-actions{(IsActive ? " reader-fragment-actions--active" : string.Empty)}{(IsInVocabulary ? " reader-fragment-actions--vocabulary" : string.Empty)}{(string.IsNullOrWhiteSpace(AdditionalClass) ? string.Empty : $" {AdditionalClass}")}";

    private string SelectActionClass =>
        "reader-fragment-action reader-fragment-action--select";

    public enum ReaderFragmentActionMode
    {
        SelectMarker,
        Popup
    }

    private Task ToggleSelectionAsync()
    {
        return IsActive
            ? UnselectClicked.InvokeAsync(Translation)
            : SelectClicked.InvokeAsync(Translation);
    }
}
