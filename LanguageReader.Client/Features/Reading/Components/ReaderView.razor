@inject ReadingApiClient ReadingApi
@inject ReadingItemsApiClient ReadingItemsApi
@inject ReadingItemTranslationsApiClient ReadingItemTranslationsApi
@inject VocabularyApiClient VocabularyApi
@inject SettingsApiClient SettingsApi
@inject TranslationApiClient TranslationApi
@inject ReaderSessionCache ReaderCache
@inject ReaderWorkspaceService ReaderWorkspace
@inject MascotService Mascot
@inject UserSession Session
@inject NavigationManager Navigation
@inject IJSRuntime JsRuntime
@inject AppErrorService Errors
@implements IAsyncDisposable

@if (!Session.IsSignedIn)
{
    <AppHeading Title="Reader" Subtitle="Open a saved reading item to continue." />
    <SignInPrompt />
}
else if (isLoading)
{
    <AppHeading Title="Reader" Subtitle="Preparing your reading session." />
    <AppLoader Label="Loading reading item" />
}
else if (content is not null)
{
    <div class="reader-shell" @onclick="ClearSelectionAsync">
        <ReadingItemHeader Details="readingItemDetails"
                           Title="@content.Title"
                           OriginalLanguage="@content.OriginalLanguage"
                           CurrentPage="@(progress.PageIndex + 1)"
                           TotalPages="@content.TotalPages"
                           ProgressPercent="@progress.ReadingPercent"
                           IsPreviousDisabled="@progress.IsFirstPage"
                           IsNextDisabled="@progress.IsLastPage"
                           PreviousClicked="PreviousPageAsync"
                       NextClicked="NextPageAsync" />


        <ReaderTextSurface @key="ReaderSurfaceKey"
                           @ref="textSurface"
                           Blocks="CurrentPageBlocks"
                           Images="content.Images"
                           TranslatedRanges="translatedRanges"
                           Selection="selection"
                           ActiveTranslation="activeTranslation"
                           ActiveMode="activeMode"
                           VocabularyEntries="vocabularyEntries"
                           IsTranslationLoading="@isTranslating"
                           IsSelectionTranslateDisabled="@(!CanTranslateSelection || isTranslating || isSavingVocabulary)"
                           LoadingTranslationId="loadingTranslationId"
                           LoadingTranslationAction="@loadingTranslationAction"
                           OffsetSelected="SelectFromOffsetTapAsync"
                           CustomRangeSelected="SelectCustomRangeAsync"
                           VisibleBlocksChanged="OnVisibleBlocksChangedAsync"
                           ScrollBlockIndex="scrollBlockIndex"
                           ScrollOffset="scrollOffset"
                           ScrollRequestKey="scrollRequestKey"
                           ScrollForce="@scrollForce"
                           ScrollRestored="OnScrollRestoredAsync"
                           TranslationSelected="SelectTranslatedRange"
                           TranslationUnselected="UnselectTranslatedRange"
                           TranslationDisplayToggleSelected="ToggleTranslationOriginalAsync"
                           TranslationVocabularyToggleSelected="ToggleTranslationVocabularyAsync"
                           TranslationOpenDetailsSelected="OpenTranslationVocabularyDetailsAsync"
                           TranslationDeleteSelected="DeleteTranslationAsync"
                           SelectionModeSelected="OnSelectionModeSelected"
                           SelectionTranslateSelected="TranslateSelectionAsync"
                           ClearSelectionRequested="ClearSelectionAsync" />
    </div>
}
else
{
    <AppHeading Title="Reader" Subtitle="Preparing your reading session." />
    <AppLoader Label="Opening reader" />
}

@code {
    [Parameter]
    public Guid ReadingItemId { get; set; }

    [Parameter]
    public int? QueryBlock { get; set; }

    [Parameter]
    public int? QueryOffset { get; set; }

    [Parameter]
    public bool IsActive { get; set; } = true;

    [Parameter]
    public long ActivationVersion { get; set; }

    [Parameter]
    public long OpenRequestVersion { get; set; }

    private readonly PeriodicTimer saveTimer = new(TimeSpan.FromSeconds(10));
    private readonly List<ReaderBlock> blocks = [];
    private readonly List<TranslatedRangeDto> translatedRanges = [];
    private readonly List<VocabularyEntryDto> vocabularyEntries = [];
    private readonly Dictionary<Guid, SelectionKind> readerSelectionKinds = [];
    private readonly ReaderSelectionService selectionService = new();
    private ReaderProgressState progress = ReaderProgressState.Empty();

    private ReaderTextSurface? textSurface;
    private ReadingItemDetailsDto? readingItemDetails;
    private ReadingItemContentPageDto? content;
    private UserSettingsDto? settings;
    private ReaderSelection? selection;
    private TranslatedRangeDto? activeTranslation;

    private string? error;
    private string? translationError;

    private bool isLoading;
    private bool isTranslating;
    private bool isSavingVocabulary;
    private Guid? loadingTranslationId;
    private string? loadingTranslationAction;

    private int? scrollBlockIndex;
    private int? scrollOffset;
    private long scrollRequestKey;
    private bool scrollForce;

    private int? selectionAnchorBlockIndex;
    private int? selectionAnchorOffset;
    private int? lastRenderedLastPageSyncIndex;
    private bool isRestoringScroll;
    private bool waitForViewportChangeAfterRestore;
    private CancellationTokenSource? progressSaveDebounce;
    private Guid? loadedReadingItemId;
    private int? loadedQueryBlock;
    private int? loadedQueryOffset;
    private long handledOpenRequestVersion;

    private SelectionKind activeMode = SelectionKind.Word;
    private CancellationTokenSource? timerCancellation;

    private bool CanTranslateSelection => selection is not null
        && string.IsNullOrWhiteSpace(selection.TranslatedText)
        && !string.IsNullOrWhiteSpace(selection.SelectedText);

    private IReadOnlyList<ReaderBlock> CurrentPageBlocks => blocks;

    private string ReaderSurfaceKey => content is null
        ? $"{ReadingItemId}:empty"
        : $"{ReadingItemId}:{content.PageIndex}:{content.StartBlockIndex}:{content.EndBlockIndex}";

    protected override void OnInitialized()
    {
        ReaderWorkspace.LeavingReader += SaveCurrentPositionBestEffortAsync;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!Session.IsSignedIn)
        {
            return;
        }

        if (content is not null
            && loadedReadingItemId == ReadingItemId
            && loadedQueryBlock == QueryBlock
            && loadedQueryOffset == QueryOffset)
        {
            if (handledOpenRequestVersion != OpenRequestVersion && QueryBlock.HasValue)
            {
                if (!IsBlockOnCurrentPage(QueryBlock.Value))
                {
                    await LoadReaderAsync();
                    handledOpenRequestVersion = OpenRequestVersion;
                    return;
                }

                progress = MoveProgressTo(QueryBlock.Value, QueryOffset ?? 0);
                QueueScrollToCurrentPosition();
                handledOpenRequestVersion = OpenRequestVersion;
            }

            return;
        }

        await LoadReaderAsync();
        handledOpenRequestVersion = OpenRequestVersion;
    }

    private bool IsBlockOnCurrentPage(int blockIndex)
    {
        return blocks.Any(block => block.Index == blockIndex);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (content is null || !progress.IsLastPage || lastRenderedLastPageSyncIndex == progress.PageIndex)
        {
            return;
        }

        lastRenderedLastPageSyncIndex = progress.PageIndex;
        await SaveProgressFromViewportAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadReaderAsync()
    {
        isLoading = true;
        error = null;
        translationError = null;
        Errors.Clear();

        try
        {
            await Session.SetLastReaderRouteAsync($"/reader/{ReadingItemId}");
            await LoadReadingItemDetailsAsync();
            await LoadUserDataAsync();

            var initialPosition = await GetInitialPositionAsync();
            await LogProgressAsync(
                "initial-position",
                new
                {
                    initialPosition.BlockIndex,
                    initialPosition.CharacterOffset,
                    QueryBlock,
                    QueryOffset
                });

            await LoadReadingItemContentPageAsync(blockIndex: initialPosition.BlockIndex);
            BuildCurrentPageBlocks();
            await LogContentPageAsync("content-page-loaded");

            progress = ReaderProgressState.Create(
                content?.TotalBlocks ?? 0,
                content?.TotalPages ?? 0,
                content?.PageIndex ?? 0,
                initialPosition.BlockIndex,
                initialPosition.CharacterOffset);

            if (ShouldRestoreScroll())
            {
                await LogProgressAsync(
                    "restore-scroll-queued",
                    new
                    {
                        progress.PageIndex,
                        progress.BlockIndex,
                        progress.CharacterOffset,
                        content?.StartBlockIndex,
                        content?.EndBlockIndex,
                        content?.TotalPages
                    });
                QueueScrollToCurrentPosition();
            }
            StartProgressTimer();

            loadedReadingItemId = ReadingItemId;
            loadedQueryBlock = QueryBlock;
            loadedQueryOffset = QueryOffset;
            handledOpenRequestVersion = OpenRequestVersion;
        }
        catch (Exception exception)
        {
            error = exception.Message;
            Errors.Show(exception);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadReadingItemDetailsAsync()
    {
        if (ReaderCache.TryGetDetails(ReadingItemId, out var cachedDetails))
        {
            readingItemDetails = cachedDetails;
            return;
        }

        readingItemDetails = await ReadingItemsApi.GetReadingItemAsync(new GetReadingItemRequest(ReadingItemId, Session.Username!));
        ReaderCache.StoreDetails(ReadingItemId, readingItemDetails);
    }

    private async Task LoadReadingItemContentPageAsync(int? pageIndex = null, int? blockIndex = null)
    {
        if (pageIndex.HasValue && ReaderCache.TryGetPage(ReadingItemId, pageIndex.Value, out var cachedPage))
        {
            content = cachedPage;
            await LogProgressAsync(
                "content-page-cache-hit",
                new
                {
                    pageIndex,
                    blockIndex,
                    cachedPage.PageIndex,
                    cachedPage.StartBlockIndex,
                    cachedPage.EndBlockIndex,
                    cachedPage.TotalPages
                });
            return;
        }

        content = await ReadingItemsApi.GetReadingItemContentAsync(
            new GetReadingItemContentRequest(
                ReadingItemId,
                Session.Username!,
                PageIndex: pageIndex,
                BlockIndex: blockIndex));

        ReaderCache.StorePage(ReadingItemId, content);
        await LogProgressAsync(
            "content-page-api-loaded",
            new
            {
                requestedPageIndex = pageIndex,
                requestedBlockIndex = blockIndex,
                content.PageIndex,
                content.StartBlockIndex,
                content.EndBlockIndex,
                content.TotalBlocks,
                content.TotalPages,
                firstBlock = content.Blocks.FirstOrDefault(block => block.BlockIndex.HasValue)?.BlockIndex,
                lastBlock = content.Blocks.LastOrDefault(block => block.BlockIndex.HasValue)?.BlockIndex
            });
    }

    private async Task LoadUserDataAsync()
    {
        settings = await SettingsApi.GetSettingsAsync(new GetUserSettingsRequest(Session.Username!));

        translatedRanges.Clear();
        translatedRanges.AddRange(await ReadingItemTranslationsApi.GetReadingItemTranslationsAsync(
            new GetReadingItemTranslationsRequest(ReadingItemId, Session.Username!)));

        vocabularyEntries.Clear();
        vocabularyEntries.AddRange(await VocabularyApi.GetVocabularyAsync(
            new GetVocabularyRequest(Session.Username!, true)));
    }

    private async Task<ReadingPositionDto> GetInitialPositionAsync()
    {
        if (QueryBlock.HasValue)
        {
            return new ReadingPositionDto(ReadingItemId, QueryBlock.Value, QueryOffset ?? 0);
        }

        var savedProgress = await ReadingApi.GetReadingProgressAsync(
            new GetReadingProgressRequest(ReadingItemId, Session.Username!));
        await LogProgressAsync(
            "saved-progress-loaded",
            new
            {
                savedProgress.ProgressPercent,
                savedProgress.Position.BlockIndex,
                savedProgress.Position.CharacterOffset,
                savedProgress.LastOpenedAtUtc
            });

        return savedProgress.Position;
    }

    private void BuildCurrentPageBlocks()
    {
        blocks.Clear();

        if (content is null)
        {
            progress = ReaderProgressState.Empty();
            return;
        }

        blocks.AddRange(ReaderDocumentParser.BuildBlocks(content.Blocks, content.StartBlockIndex));
    }

    private Task OnVisibleBlocksChangedAsync(ReaderVisibleBlocks visibleBlocks)
    {
        if (isRestoringScroll)
        {
            _ = LogProgressAsync(
                "visible-blocks-ignored-during-restore",
                new
                {
                    visibleBlocks.ProgressBlockIndex,
                    visibleBlocks.BookmarkBlockIndex
                });
            return Task.CompletedTask;
        }

        var next = progress.MoveToVisibleBlocks(
            visibleBlocks.ProgressBlockIndex,
            visibleBlocks.BookmarkBlockIndex);
        waitForViewportChangeAfterRestore = false;

        if (next.Equals(progress))
        {
            _ = LogProgressAsync(
                "visible-blocks-unchanged",
                new
                {
                    visibleProgressBlockIndex = visibleBlocks.ProgressBlockIndex,
                    visibleBookmarkBlockIndex = visibleBlocks.BookmarkBlockIndex,
                    progress.PageIndex,
                    progress.BlockIndex,
                    progress.CharacterOffset,
                    progress.ProgressBlockIndex
                });
            return Task.CompletedTask;
        }

        progress = next;
        lastRenderedLastPageSyncIndex = null;
        _ = LogProgressAsync(
            "visible-blocks-applied",
            new
            {
                visibleBlocks.ProgressBlockIndex,
                visibleBlocks.BookmarkBlockIndex,
                progress.PageIndex,
                progress.BlockIndex,
                progress.CharacterOffset,
                progress.ReadingPercent
            });
        ScheduleProgressSave();
        return InvokeAsync(StateHasChanged);
    }

    private Task SelectFromOffsetTapAsync(ReaderOffsetTap tap)
    {
        SelectFromOffset(tap.Block, tap.Offset);
        progress = MoveProgressTo(tap.Block.Index, tap.Offset);
        lastRenderedLastPageSyncIndex = null;
        return SaveCurrentPositionAsync();
    }

    private Task SelectCustomRangeAsync(ReaderCustomSelectionRange range)
    {
        var paragraph = blocks.FirstOrDefault(item => item.Index == range.BlockIndex);
        if (paragraph is null)
        {
            return Task.CompletedTask;
        }

        var nextSelection = selectionService.BuildCustomSelection(paragraph, range);
        if (nextSelection is null)
        {
            return Task.CompletedTask;
        }

        if (IsExistingTranslationSelection(nextSelection))
        {
            ClearSelection();
            return Task.CompletedTask;
        }

        ApplySelection(nextSelection);
        progress = MoveProgressTo(nextSelection.BlockIndex, nextSelection.StartOffset);
        lastRenderedLastPageSyncIndex = null;
        return Task.CompletedTask;
    }

    private void SelectFromOffset(ReaderBlock paragraph, int offset)
    {
        var nextSelection = selectionService.BuildFromOffset(
            paragraph,
            offset,
            activeMode);

        if (nextSelection is null)
        {
            return;
        }

        if (IsExistingTranslationSelection(nextSelection))
        {
            ClearSelection();
            return;
        }

        ApplySelection(nextSelection);
    }

    private Task OnSelectionModeSelected(SelectionKind mode)
    {
        activeMode = mode;
        translationError = null;
        Errors.Clear();
        activeTranslation = null;

        if (selection is null)
        {
            return Task.CompletedTask;
        }

        var anchorBlockIndex = selectionAnchorBlockIndex ?? selection.BlockIndex;
        var anchorOffset = selectionAnchorOffset ?? selection.AnchorOffset;

        var nextSelection = selectionService.ReselectFromAnchor(
            mode,
            anchorBlockIndex,
            anchorOffset,
            blocks);

        if (nextSelection is null)
        {
            return Task.CompletedTask;
        }

        if (IsExistingTranslationSelection(nextSelection))
        {
            ClearSelection();
            return Task.CompletedTask;
        }

        selection = nextSelection;
        RememberSelectionAnchor(selection);

        return Task.CompletedTask;
    }

    private void RememberSelectionAnchor(ReaderSelection? readerSelection)
    {
        if (readerSelection is null)
        {
            return;
        }

        selectionAnchorBlockIndex = readerSelection.BlockIndex;
        selectionAnchorOffset = readerSelection.AnchorOffset;
    }

    private async Task TranslateSelectionAsync()
    {
        var currentSelection = selection;
        if (currentSelection is null
            || !string.IsNullOrWhiteSpace(currentSelection.TranslatedText)
            || string.IsNullOrWhiteSpace(currentSelection.SelectedText)
            || IsExistingTranslationSelection(currentSelection))
        {
            if (currentSelection is not null && IsExistingTranslationSelection(currentSelection))
            {
                ClearSelection();
            }

            return;
        }

        isTranslating = true;
        translationError = null;
        Errors.Clear();

        try
        {
            settings ??= await SettingsApi.GetSettingsAsync(new GetUserSettingsRequest(Session.Username!));

            var result = await TranslationApi.TranslateAsync(
                new TranslateRequest(
                    Session.Username!,
                    settings.NativeLanguage ?? string.Empty,
                    readingItemDetails?.OriginalLanguage ?? content?.OriginalLanguage ?? string.Empty,
                    currentSelection.SelectionType,
                    currentSelection.SelectedText,
                    BuildTranslationContext(currentSelection),
                    ReadingItemId,
                    CurrentPosition()));

            var saved = await ReadingItemTranslationsApi.CreateReadingItemTranslationAsync(
                new CreateTranslatedRangeRequest(
                    ReadingItemId,
                    currentSelection.SelectedText,
                    result.Translation,
                    currentSelection.BlockIndex,
                    currentSelection.StartOffset,
                    currentSelection.EndOffset,
                    Session.Username!,
                    currentSelection.SelectionType,
                    result.Usage));
            RememberReaderSelectionKind(saved.Id, currentSelection.SelectionType);
            ReplaceTranslatedRange(saved);
            SelectTranslatedRange(saved);
        }
        catch (Exception exception)
        {
            translationError = exception.Message;
            Errors.Show(exception);
        }
        finally
        {
            isTranslating = false;
        }
    }

    private async Task ToggleTranslationVocabularyAsync(TranslatedRangeDto range)
    {
        BeginTranslationAction(range, TranslationActionKind.Vocabulary);

        var entry = GetVocabularyEntry(range, includeHidden: true);
        isSavingVocabulary = true;
        translationError = null;
        Errors.Clear();

        try
        {
            if (entry is not null)
            {
                await SetVocabularyVisibilityAsync(entry, !entry.IsVisibleInVocabulary);
                return;
            }

            settings ??= await SettingsApi.GetSettingsAsync(new GetUserSettingsRequest(Session.Username!));

            var sourceLanguage = readingItemDetails?.OriginalLanguage ?? content?.OriginalLanguage;
            var targetLanguage = settings.NativeLanguage ?? string.Empty;
            var vocabularySelectionKind = GetReaderSelectionKind(range);

            var saved = await VocabularyApi.SaveVocabularyAsync(new SaveVocabularyEntryRequest(
                Session.Username!,
                range.OriginalText,
                range.TranslatedText,
                sourceLanguage,
                targetLanguage,
                ReadingItemId,
                new ReadingPositionDto(ReadingItemId, range.BlockIndex, range.StartOffset),
                selectionService.GetContextSentence(blocks, range.BlockIndex, range.StartOffset),
                true,
                vocabularySelectionKind));

            ReplaceVocabularyEntry(saved);
            ReplaceTranslatedRange(range with { VocabularyEntryId = saved.Id, Kind = saved.Kind });
        }
        catch (Exception exception)
        {
            translationError = exception.Message;
            Errors.Show(exception);
        }
        finally
        {
            isSavingVocabulary = false;
            EndTranslationAction(range);
        }
    }

    private async Task SetVocabularyVisibilityAsync(VocabularyEntryDto entry, bool isVisible)
    {
        isSavingVocabulary = true;
        translationError = null;
        Errors.Clear();

        try
        {
            var updated = await VocabularyApi.UpdateVocabularyVisibilityAsync(
                new UpdateVocabularyVisibilityRequest(entry.Id, Session.Username!, isVisible));

            ReplaceVocabularyEntry(updated);
        }
        catch (Exception exception)
        {
            translationError = exception.Message;
            Errors.Show(exception);
        }
        finally
        {
            isSavingVocabulary = false;
        }
    }

    private void SelectTranslatedRange(TranslatedRangeDto range)
    {
        activeTranslation = range;

        selection = new ReaderSelection(
            activeMode,
            range.OriginalText,
            range.BlockIndex,
            range.StartOffset,
            range.EndOffset,
            range.StartOffset,
            GetReaderSelectionKind(range),
            range.TranslatedText);

        RememberSelectionAnchor(selection);

        @* QueueScrollTo(range.BlockIndex, range.StartOffset); *@
    }

    private Task UnselectTranslatedRange(TranslatedRangeDto range)
    {
        if (activeTranslation?.Id == range.Id)
        {
            activeTranslation = null;
            selection = null;
        }

        return Task.CompletedTask;
    }

    private async Task ToggleTranslationOriginalAsync(TranslatedRangeDto range)
    {
        BeginTranslationAction(range, TranslationActionKind.Display);

        try
        {
            var updated = await ReadingItemTranslationsApi.UpdateReadingItemTranslationDisplayAsync(
                new UpdateTranslatedRangeDisplayRequest(ReadingItemId, range.Id, Session.Username!, !range.ShowOriginal));

            ReplaceTranslatedRange(updated);
            SelectTranslatedRange(updated);
        }
        catch (Exception exception)
        {
            translationError = exception.Message;
            Errors.Show(exception);
        }
        finally
        {
            EndTranslationAction(range);
        }
    }

    private async Task DeleteTranslationAsync(TranslatedRangeDto range)
    {
        BeginTranslationAction(range, TranslationActionKind.Delete);

        try
        {
            await ReadingItemTranslationsApi.DeleteReadingItemTranslationAsync(
                new DeleteReadingItemTranslationRequest(ReadingItemId, range.Id, Session.Username!));

            translatedRanges.RemoveAll(item => item.Id == range.Id);
            ClearSelection();
        }
        catch (Exception exception)
        {
            translationError = exception.Message;
            Errors.Show(exception);
        }
        finally
        {
            EndTranslationAction(range);
        }
    }

    private async Task PreviousPageAsync()
    {
        if (progress.IsFirstPage)
        {
            return;
        }

        await LoadReadingItemContentPageAsync(pageIndex: progress.PageIndex - 1);
        BuildCurrentPageBlocks();
        progress = progress.MoveToPage(
            content?.PageIndex ?? 0,
            content?.StartBlockIndex ?? 0,
            content?.TotalBlocks ?? 0,
            content?.TotalPages ?? 0);
        lastRenderedLastPageSyncIndex = null;
        selection = null;
        QueueScrollToCurrentPosition();
        Mascot.PlayAction(MascotAction.TurnPage, MascotState.Reading);
        await SaveCurrentPositionAsync();
    }

    private async Task NextPageAsync()
    {
        if (progress.IsLastPage)
        {
            return;
        }

        await LoadReadingItemContentPageAsync(pageIndex: progress.PageIndex + 1);
        BuildCurrentPageBlocks();
        progress = progress.MoveToPage(
            content?.PageIndex ?? 0,
            content?.StartBlockIndex ?? 0,
            content?.TotalBlocks ?? 0,
            content?.TotalPages ?? 0);
        lastRenderedLastPageSyncIndex = null;
        selection = null;
        QueueScrollToCurrentPosition();
        Mascot.PlayAction(MascotAction.TurnPage, MascotState.Reading);
        await SaveCurrentPositionAsync();
    }

    private void ApplySelection(ReaderSelection readerSelection)
    {
        selection = readerSelection;
        translationError = null;
        Errors.Clear();
        activeTranslation = null;

        if (readerSelection.SelectionType is SelectionKind.Word or SelectionKind.Sentence or SelectionKind.Paragraph)
        {
            activeMode = readerSelection.SelectionType;
        }

        selectionAnchorBlockIndex = readerSelection.BlockIndex;
        selectionAnchorOffset = readerSelection.AnchorOffset;
    }

    private bool IsExistingTranslationSelection(ReaderSelection readerSelection)
    {
        return translatedRanges.Any(range =>
            range.BlockIndex == readerSelection.BlockIndex
            && RangesOverlap(range.StartOffset, range.EndOffset, readerSelection.StartOffset, readerSelection.EndOffset)
            && string.Equals(
                NormalizeSelectionText(range.OriginalText),
                NormalizeSelectionText(readerSelection.SelectedText),
                StringComparison.Ordinal));
    }

    private static bool RangesOverlap(int firstStart, int firstEnd, int secondStart, int secondEnd)
    {
        return firstStart < secondEnd && secondStart < firstEnd;
    }

    private static string NormalizeSelectionText(string value)
    {
        return string.Join(
            " ",
            value.Split((char[]?)null, StringSplitOptions.RemoveEmptyEntries));
    }

    private Task ClearSelectionAsync()
    {
        ClearSelection();
        return Task.CompletedTask;
    }

    private ReaderProgressState MoveProgressTo(int blockIndex, int characterOffset, int? progressBlockIndex = null)
    {
        var next = progress.MoveTo(
            blockIndex,
            characterOffset,
            content?.TotalBlocks ?? 0,
            content?.TotalPages ?? 0,
            content?.PageIndex ?? 0);

        return progressBlockIndex.HasValue && next.TotalBlocks > 0
            ? next with { ProgressBlockIndex = Math.Clamp(progressBlockIndex.Value, 0, next.TotalBlocks - 1) }
            : next;
    }

    private void ClearSelection()
    {
        selection = null;
        activeTranslation = null;
        selectionAnchorBlockIndex = null;
        selectionAnchorOffset = null;
    }

    private void ReplaceTranslatedRange(TranslatedRangeDto updated)
    {
        translatedRanges.RemoveAll(range => range.Id == updated.Id);
        translatedRanges.Add(updated);
        activeTranslation = updated;
    }

    private void ReplaceVocabularyEntry(VocabularyEntryDto saved)
    {
        vocabularyEntries.RemoveAll(entry => entry.Id == saved.Id);
        vocabularyEntries.RemoveAll(entry =>
            entry.Id != saved.Id
            && entry.ReadingItemId == saved.ReadingItemId
            && string.Equals(entry.Word, saved.Word, StringComparison.OrdinalIgnoreCase)
            && entry.TargetLanguage == saved.TargetLanguage);

        vocabularyEntries.Add(saved);
    }

    private VocabularyEntryDto? GetVocabularyEntry(TranslatedRangeDto range, bool includeHidden = false)
    {
        if (range.VocabularyEntryId.HasValue)
        {
            return vocabularyEntries
                .OrderByDescending(entry => entry.CreatedAtUtc)
                .FirstOrDefault(entry =>
                    (includeHidden || entry.IsVisibleInVocabulary)
                    && entry.Id == range.VocabularyEntryId.Value);
        }

        return vocabularyEntries
            .Where(entry => entry.ReadingItemId == range.ReadingItemId)
            .OrderByDescending(entry => entry.CreatedAtUtc)
            .FirstOrDefault(entry =>
                (includeHidden || entry.IsVisibleInVocabulary)
                && entry.Position?.BlockIndex == range.BlockIndex
                && entry.Position?.CharacterOffset == range.StartOffset
                && entry.Kind == range.Kind
                && string.Equals(entry.Word, range.OriginalText, StringComparison.OrdinalIgnoreCase));
    }

    private void RememberReaderSelectionKind(Guid translatedRangeId, SelectionKind selectionKind)
    {
        readerSelectionKinds[translatedRangeId] = selectionKind;
    }

    private SelectionKind GetReaderSelectionKind(TranslatedRangeDto range)
    {
        if (readerSelectionKinds.TryGetValue(range.Id, out var selectionKind))
        {
            return selectionKind;
        }

        return range.Kind == SavedTextKind.LexicalUnit
            ? SelectionKind.Word
            : SelectionKind.Paragraph;
    }

    private ReadingPositionDto CurrentPosition()
    {
        return new ReadingPositionDto(ReadingItemId, progress.BlockIndex, progress.CharacterOffset);
    }

    private string? BuildTranslationContext(ReaderSelection readerSelection)
    {
        return readerSelection.SelectionType is SelectionKind.Word or SelectionKind.Unknown
            ? selectionService.GetContextWindow(blocks, readerSelection.BlockIndex, readerSelection.StartOffset)
            : readerSelection.SelectedText;
    }

    private async Task SaveCurrentPositionAsync()
    {
            await SaveProgressFromViewportAsync();
    }

    private async Task SaveProgressFromViewportAsync()
    {
        if (!Session.IsSignedIn)
        {
            return;
        }

        if (isRestoringScroll || waitForViewportChangeAfterRestore)
        {
            await LogProgressAsync(
                "save-progress-skipped-after-restore",
                new
                {
                    isRestoringScroll,
                    waitForViewportChangeAfterRestore,
                    progress.PageIndex,
                    progress.BlockIndex,
                    progress.CharacterOffset,
                    progress.ProgressBlockIndex
                });
            return;
        }

        var viewportProgress = textSurface is null
            ? null
            : await textSurface.GetViewportProgressAsync(ReadingItemId);

        await SaveProgressAsync(
            viewportProgress?.Position ?? CurrentPosition(),
            viewportProgress?.ProgressBlockIndex);
    }

    private async Task SaveProgressAsync(ReadingPositionDto position, int? progressBlockIndex = null)
    {
        progress = MoveProgressTo(position.BlockIndex, position.CharacterOffset, progressBlockIndex);
        await LogProgressAsync(
            "save-progress",
            new
            {
                requestedPosition = new
                {
                    position.BlockIndex,
                    position.CharacterOffset
                },
                progressBlockIndex,
                persistedPosition = new
                {
                    progress.BlockIndex,
                    progress.CharacterOffset
                },
                progress.PageIndex,
                progress.ReadingPercent
            });

        await ReadingApi.SaveReadingProgressAsync(
            new SaveReadingProgressRequest(
                ReadingItemId,
                Session.Username!,
                progress.ReadingPercent,
                position));
    }

    private void StartProgressTimer()
    {
        timerCancellation?.Cancel();
        timerCancellation = new CancellationTokenSource();
        _ = SaveProgressLoopAsync(timerCancellation.Token);
    }

    private void ScheduleProgressSave()
    {
        progressSaveDebounce?.Cancel();
        progressSaveDebounce?.Dispose();
        progressSaveDebounce = new CancellationTokenSource();
        var token = progressSaveDebounce.Token;
        var scheduledPosition = CurrentPosition();

        _ = LogProgressAsync(
            "save-progress-scheduled",
            new
            {
                scheduledPosition.BlockIndex,
                scheduledPosition.CharacterOffset,
                progress.PageIndex,
                progress.ProgressBlockIndex,
                progress.ReadingPercent
            });

        _ = Task.Run(async () =>
        {
            try
            {
                await Task.Delay(850, token);
                if (!token.IsCancellationRequested)
                {
                    await InvokeAsync(() => LogProgressAsync(
                        "save-progress-debounce-fired",
                        new
                        {
                            progress.BlockIndex,
                            progress.CharacterOffset,
                            progress.ProgressBlockIndex,
                            progress.ReadingPercent
                        }));
                    await InvokeAsync(SaveProgressBestEffortAsync);
                }
            }
            catch (OperationCanceledException)
            {
            }
            catch
            {
                // Periodic progress saving is best-effort; explicit reader actions still surface errors.
            }
        }, token);
    }

    private async Task SaveProgressBestEffortAsync()
    {
        try
        {
            await SaveProgressFromViewportAsync();
        }
        catch (Exception exception)
        {
            await LogProgressAsync(
                "save-progress-failed",
                new
                {
                    exception.Message,
                    exception.StackTrace
            });
        }
    }

    private async Task SaveCurrentPositionBestEffortAsync()
    {
        try
        {
            await SaveCurrentPositionAsync();
        }
        catch
        {
            // Background progress persistence should not interrupt navigation or reading.
        }
    }

    private void CancelProgressPersistence()
    {
        progressSaveDebounce?.Cancel();
        timerCancellation?.Cancel();
    }

    private async Task SaveProgressLoopAsync(CancellationToken cancellationToken)
    {
        try
        {
            while (await saveTimer.WaitForNextTickAsync(cancellationToken))
            {
                await SaveProgressFromViewportAsync();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private void QueueScrollToCurrentPosition()
    {
        QueueScrollTo(progress.BlockIndex, progress.CharacterOffset, force: true, suppressViewportProgress: true);
    }

    private bool ShouldRestoreScroll()
    {
        if (QueryBlock.HasValue)
        {
            return true;
        }

        return progress.BlockIndex > 0 || progress.CharacterOffset > 0;
    }

    private void QueueScrollTo(
        int targetBlockIndex,
        int targetOffset,
        bool force = false,
        bool suppressViewportProgress = false)
    {
        if (suppressViewportProgress)
        {
            isRestoringScroll = true;
        }

        scrollBlockIndex = targetBlockIndex;
        scrollOffset = targetOffset;
        scrollForce = force;
        scrollRequestKey++;
    }

    private async Task OnScrollRestoredAsync()
    {
        if (!isRestoringScroll)
        {
            return;
        }

        isRestoringScroll = false;
        waitForViewportChangeAfterRestore = true;
        await LogProgressAsync(
            "scroll-restored",
            new
            {
                progress.PageIndex,
                progress.BlockIndex,
                progress.CharacterOffset,
                scrollBlockIndex,
                scrollOffset,
                scrollForce
            });
    }

    private Task LogContentPageAsync(string eventName)
    {
        return LogProgressAsync(
            eventName,
            new
            {
                content?.PageIndex,
                content?.StartBlockIndex,
                content?.EndBlockIndex,
                content?.TotalBlocks,
                content?.TotalPages,
                blocks = blocks.Select(block => block.Index).Where(index => index >= 0).ToArray()
            });
    }

    private async Task LogProgressAsync(string eventName, object data)
    {
        await Task.CompletedTask;
    }

    private void BeginTranslationAction(TranslatedRangeDto range, string action)
    {
        loadingTranslationId = range.Id;
        loadingTranslationAction = action;
    }

    private void EndTranslationAction(TranslatedRangeDto range)
    {
        if (loadingTranslationId == range.Id)
        {
            loadingTranslationId = null;
            loadingTranslationAction = null;
        }
    }

    private async Task GoBack()
    {
        await ReaderWorkspace.ShowMainAsync();
        Navigation.NavigateTo("");
    }

    private async Task OpenVocabularyLibraryAsync()
    {
        await ReaderWorkspace.ShowMainAsync();
        Navigation.NavigateTo("/vocabulary");
    }

    private async Task OpenTranslationVocabularyDetailsAsync(TranslatedRangeDto range)
    {
        var entry = GetVocabularyEntry(range, includeHidden: true);
        if (entry is null)
        {
            return;
        }
        
        var returnUrl = Uri.EscapeDataString($"/reader/{ReadingItemId}?block={progress.BlockIndex}&offset={progress.CharacterOffset}");
        await ReaderWorkspace.ShowMainAsync();
        Navigation.NavigateTo($"/words/{entry.Id}?returnUrl={returnUrl}");
    }

    public async ValueTask DisposeAsync()
    {
        ReaderWorkspace.LeavingReader -= SaveCurrentPositionBestEffortAsync;
        CancelProgressPersistence();

        try
        {
            if (Session.IsSignedIn && content is not null)
            {
                await SaveCurrentPositionBestEffortAsync();
            }
        }
        catch
        {
            // The reader may be disposing during navigation or browser shutdown.
        }
        finally
        {
            progressSaveDebounce?.Dispose();
            timerCancellation?.Dispose();
            saveTimer.Dispose();
        }
    }

    private static class TranslationActionKind
    {
        public const string Display = "display";
        public const string Vocabulary = "vocabulary";
        public const string Delete = "delete";
    }
