<div class="reader-bottom-dock">
    <div class="reader-dock-bar">
        <AppButton Variant="ghost"
                   Size="sm"
                   Icon="chevron_left"
                   IconOnly="true"
                   Title="Previous page"
                   Disabled="@IsPreviousDisabled"
                   OnClick="@(_ => PreviousClicked.InvokeAsync())" />

        <div class="reader-dock-label">Page @CurrentPage of @TotalPages</div>

        <AppButton Variant="ghost"
                   Size="sm"
                   Icon="chevron_right"
                   IconOnly="true"
                   Title="Next page"
                   Disabled="@IsNextDisabled"
                   OnClick="@(_ => NextClicked.InvokeAsync())" />
    </div>
</div>

@code {
    [Parameter]
    public int CurrentPage { get; set; }

    [Parameter]
    public int TotalPages { get; set; }

    [Parameter]
    public double ProgressPercent { get; set; }

    [Parameter]
    public bool IsPreviousDisabled { get; set; }

    [Parameter]
    public bool IsNextDisabled { get; set; }

    [Parameter]
    public EventCallback PreviousClicked { get; set; }

    [Parameter]
    public EventCallback NextClicked { get; set; }
}
