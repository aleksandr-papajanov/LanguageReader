<div class="reader-bottom-dock">
    <AppButton Label="Previous page"
               Title="Previous page"
               Icon="chevron_left"
               IconOnly="true"
               Variant="ghost"
               Size="sm"
               Disabled="@IsPreviousDisabled"
               IsLoading="@isPreviousLoading"
               OnClick="HandlePreviousClickedAsync" />

    <div class="reader-bottom-dock__status">
        <strong>Page @CurrentPage of @TotalPages</strong>
        <AppProgressBar Value="@ProgressPercent" />
    </div>

    <AppButton Label="Next page"
               Title="Next page"
               Icon="chevron_right"
               IconOnly="true"
               Variant="ghost"
               Size="sm"
               Disabled="@IsNextDisabled"
               IsLoading="@isNextLoading"
               OnClick="HandleNextClickedAsync" />
</div>

@code {
    private bool isPreviousLoading;
    private bool isNextLoading;

    [Parameter]
    public int CurrentPage { get; set; }

    [Parameter]
    public int TotalPages { get; set; }

    [Parameter]
    public double ProgressPercent { get; set; }

    [Parameter]
    public bool IsPreviousDisabled { get; set; }

    [Parameter]
    public bool IsNextDisabled { get; set; }

    [Parameter]
    public EventCallback PreviousClicked { get; set; }

    [Parameter]
    public EventCallback NextClicked { get; set; }

    private async Task HandlePreviousClickedAsync(MouseEventArgs _)
    {
        if (IsPreviousDisabled || isPreviousLoading)
        {
            return;
        }

        isPreviousLoading = true;
        try
        {
            await PreviousClicked.InvokeAsync();
        }
        finally
        {
            isPreviousLoading = false;
        }
    }

    private async Task HandleNextClickedAsync(MouseEventArgs _)
    {
        if (IsNextDisabled || isNextLoading)
        {
            return;
        }

        isNextLoading = true;
        try
        {
            await NextClicked.InvokeAsync();
        }
        finally
        {
            isNextLoading = false;
        }
    }
}
