@page "/reader/{ReadingItemId:guid}"
@inject ReaderWorkspaceService Workspace

<PageTitle>Reader</PageTitle>

@code {
    [Parameter]
    public Guid ReadingItemId { get; set; }

    [SupplyParameterFromQuery(Name = "block")]
    public int? QueryBlock { get; set; }

    [SupplyParameterFromQuery(Name = "offset")]
    public int? QueryOffset { get; set; }

    protected override void OnParametersSet()
    {
        if (Workspace.ShouldIgnoreRouteActivation(ReadingItemId))
        {
            return;
        }

        Workspace.Open(ReadingItemId, QueryBlock, QueryOffset);
    }
}
