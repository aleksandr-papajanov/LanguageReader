@page "/reader/{ReadingItemId:guid}"

<PageTitle>Reader</PageTitle>

<ReaderView ReadingItemId="ReadingItemId" QueryBlock="QueryBlock" QueryOffset="QueryOffset" />

@code {
    [Parameter]
