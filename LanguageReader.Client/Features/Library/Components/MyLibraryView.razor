@inject ReadingItemImportsApiClient Api
@inject NavigationManager Navigation
@inject UserSession Session
@inject AppErrorService Errors

<AppHeading Title="Add Reading Item"
            Subtitle="Import an FB2 or XML source into your private library." />

@if (!Session.IsSignedIn)
{
    <SignInPrompt />
}
else
{
    <ReadingItemUploadForm Tabs="@ReadingItemUploadState.ImportTabs"
                           ActiveImportTab="@state.ActiveImportTab"
                           Title="@state.Title"
                           OriginalLanguage="@state.OriginalLanguage"
                           Url="@state.Url"
                           Preview="@state.Preview"
                           IsPreviewOpen="@state.IsPreviewOpen"
                           IsPreviewing="@state.IsPreviewing"
                           HasSelectedFile="@state.HasSelectedFile"
                           IsBusy="@state.IsBusy"
                           ImportTabChanged="@state.SelectImportTab"
                           TitleChanged="@state.OnTitleChanged"
                           OriginalLanguageChanged="@state.OnOriginalLanguageChanged"
                           UrlChanged="@state.OnUrlChanged"
                           FileSelected="@state.OnFileSelected"
                           UploadClicked="UploadAsync"
                           PreviewUrlClicked="PreviewUrlAsync"
                           ConfirmPreviewClicked="ConfirmUrlImportAsync"
                           PreviewClosed="@state.ClosePreview" />
}

@code {
    private readonly ReadingItemUploadState state = new();

    private async Task UploadAsync()
    {
        await state.UploadAsync(Api, Navigation, Session.Username!);
        ShowStateErrors();
    }

    private async Task PreviewUrlAsync()
    {
        await state.PreviewUrlAsync(Api);
        ShowStateErrors();
    }

    private async Task ConfirmUrlImportAsync()
    {
        await state.ConfirmUrlImportAsync(Api, Navigation, Session.Username!);
        ShowStateErrors();
    }

    private void ShowStateErrors()
    {
        if (!string.IsNullOrWhiteSpace(state.Error))
        {
            Errors.Show(state.Error);
        }

        if (!string.IsNullOrWhiteSpace(state.PreviewError))
        {
            Errors.Show(state.PreviewError);
        }
    }
}
