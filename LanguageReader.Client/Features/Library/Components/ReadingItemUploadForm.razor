@using LanguageReader.Client.Features.ReadingItems.Components

<AppPanel AdditionalClass="form-panel">
    <AppHeading Title="Add Reading Item"
                Subtitle="Import an FB2/XML file or save a readable web article."
                Level="section" />

    <AppTabs Items="Tabs"
             ActiveValue="@ActiveImportTab"
             ActiveValueChanged="ImportTabChanged"
             AriaLabel="Import source" />

    @if (ActiveImportTab == "file")
    {
        <AppTextInput Id="title"
                      Label="Title"
                      Value="@Title"
                      ValueChanged="TitleChanged"
                      LeadingIcon="book_2" />

        <LanguageSelect Id="original-language"
                        Label="Original Language"
                        Value="@OriginalLanguage"
                        ValueChanged="OriginalLanguageChanged" />

        <AppField Label="Source File" Hint="FB2 or XML source" For="file">
            <InputFile id="file" class="app-input" OnChange="OnFileSelected" accept=".fb2,.xml" />
        </AppField>

        <AppButton Label="Upload"
                   Variant="primary"
                   Icon="upload"
                   Disabled="@IsUploadDisabled"
                   IsLoading="@IsBusy"
                   OnClick="OnUploadClicked" />
    }
    else
    {
        <AppTextInput Id="source-url"
                      Label="Article URL"
                      Value="@Url"
                      ValueChanged="UrlChanged"
                      LeadingIcon="link"
                      Placeholder="https://example.com/article"
                      Type="url" />

        <AppTextInput Id="url-title"
                      Label="Title"
                      Hint="Optional. If empty, the parsed title will be used."
                      Value="@Title"
                      ValueChanged="TitleChanged"
                      LeadingIcon="book_2" />

        <LanguageSelect Id="url-original-language"
                        Label="Original Language"
                        Value="@OriginalLanguage"
                        ValueChanged="OriginalLanguageChanged" />

        <AppButton Label="Preview"
                   Variant="primary"
                   Icon="visibility"
                   Disabled="@IsUrlPreviewDisabled"
                   IsLoading="@IsPreviewing"
                   OnClick="OnPreviewUrlClicked" />
    }
</AppPanel>

<ReadingItemImportPreviewModal IsOpen="@IsPreviewOpen"
                               Preview="@Preview"
                               IsBusy="@IsBusy"
                               IsLoading="@IsPreviewing"
                               ConfirmLabel="Save"
                               Confirmed="ConfirmPreviewClicked"
                               Closed="PreviewClosed" />

@code {
    [Parameter]
    public IReadOnlyList<AppTabItem> Tabs { get; set; } = [];

    [Parameter]
    public string ActiveImportTab { get; set; } = "file";

    [Parameter]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string OriginalLanguage { get; set; } = "English";

    [Parameter]
    public string Url { get; set; } = string.Empty;

    [Parameter]
    public ReadingItemImportPreviewDto? Preview { get; set; }

    [Parameter]
    public bool IsPreviewOpen { get; set; }

    [Parameter]
    public bool IsPreviewing { get; set; }

    [Parameter]
    public bool IsBusy { get; set; }

    [Parameter]
    public bool HasSelectedFile { get; set; }

    [Parameter]
    public EventCallback<string> TitleChanged { get; set; }

    [Parameter]
    public EventCallback<string> OriginalLanguageChanged { get; set; }

    [Parameter]
    public EventCallback<string> UrlChanged { get; set; }

    [Parameter]
    public EventCallback<string> ImportTabChanged { get; set; }

    [Parameter]
    public EventCallback<InputFileChangeEventArgs> FileSelected { get; set; }

    [Parameter]
    public EventCallback UploadClicked { get; set; }

    [Parameter]
    public EventCallback PreviewUrlClicked { get; set; }

    [Parameter]
    public EventCallback ConfirmPreviewClicked { get; set; }

    [Parameter]
    public EventCallback PreviewClosed { get; set; }

    private bool IsUploadDisabled => !HasSelectedFile || IsBusy;

    private bool IsUrlPreviewDisabled => string.IsNullOrWhiteSpace(Url) || IsPreviewing || IsBusy;

    private Task OnFileSelected(InputFileChangeEventArgs args)
    {
        return FileSelected.InvokeAsync(args);
    }

    private Task OnUploadClicked(MouseEventArgs _)
    {
        return UploadClicked.InvokeAsync();
    }

    private Task OnPreviewUrlClicked(MouseEventArgs _)
    {
        return PreviewUrlClicked.InvokeAsync();
    }

}
