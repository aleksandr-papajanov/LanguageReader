<div class="app-dropdown">
    <AppButton Label="@ButtonLabel"
               Variant="@ButtonVariant"
               Size="@ButtonSize"
               Icon="@ButtonIcon"
               IconOnly="@ButtonIconOnly"
               Title="@ButtonTitle"
               Disabled="@Disabled"
               AdditionalClass="app-dropdown__trigger"
               OnClick="ToggleMenu" />

    @if (isOpen)
    {
        <div class="@MenuClass" role="menu">
            @foreach (var item in Items)
            {
                <AppButton Label="@item.Label"
                           Variant="@item.Variant"
                           Size="sm"
                           Icon="@item.Icon"
                           Disabled="@item.Disabled"
                           AdditionalClass="app-dropdown__item"
                           OnClick="@(_ => Select(item))" />
            }
        </div>
    }
</div>

@code {
    [Parameter]
    public string? ButtonLabel { get; set; }

    [Parameter]
    public string? ButtonIcon { get; set; }

    [Parameter]
    public string ButtonVariant { get; set; } = "secondary";

    [Parameter]
    public string ButtonSize { get; set; } = "sm";

    [Parameter]
    public bool ButtonIconOnly { get; set; }

    [Parameter]
    public string? ButtonTitle { get; set; }

    [Parameter]
    public bool OpenUpward { get; set; } = true;

    [Parameter]
    public string Align { get; set; } = "start";

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public IReadOnlyList<AppMenuItem> Items { get; set; } = [];

    [Parameter]
    public EventCallback<string> ItemSelected { get; set; }

    private bool isOpen;

    private string MenuClass
    {
        get
        {
            var classes = new List<string> { "app-dropdown__menu" };

            if (OpenUpward)
            {
                classes.Add("app-dropdown__menu--up");
            }

            if (Align == "end")
            {
                classes.Add("app-dropdown__menu--align-end");
            }

            return string.Join(" ", classes);
        }
    }

    private Task ToggleMenu(MouseEventArgs _)
    {
        if (!Disabled)
        {
            isOpen = !isOpen;
        }

        return Task.CompletedTask;
    }

    private async Task Select(AppMenuItem item)
    {
        if (item.Disabled)
        {
            return;
        }

        isOpen = false;
        await ItemSelected.InvokeAsync(item.Key);
    }
}
