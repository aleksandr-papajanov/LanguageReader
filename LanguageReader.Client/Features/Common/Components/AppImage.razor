@inject IJSRuntime JsRuntime
@implements IAsyncDisposable

<div class="@WrapperClass" style="@WrapperStyle">
    @if (ShouldShowLoading)
    {
        <span class="app-image__loading" aria-hidden="true">
            <span class="app-image__loading-glow"></span>
        </span>
    }

    @if (UseMask)
    {
        <span class="@MediaClassName"
              style="@MaskStyle"
              role="@CanvasRole"
              aria-label="@CanvasLabel"
              aria-hidden="@Decorative"></span>
    }
    else if (ShouldRenderImage)
    {
        <img src="@Src"
             alt="@ResolvedAlt"
             class="@MediaClassName"
             style="@ImageStyle"
             loading="@Loading"
             decoding="@Decoding"
             draggable="false"
             @onload="HandleImageLoaded"
             @onerror="HandleImageError"
             aria-hidden="@Decorative" />
    }
    else
    {
        <canvas @ref="canvas"
                class="@MediaClassName"
                style="@ImageStyle"
                role="@CanvasRole"
                aria-label="@CanvasLabel"
                aria-hidden="@Decorative"></canvas>
    }
</div>

@code {
    private ElementReference canvas;
    private CancellationTokenSource? renderCancellation;
    private string? renderedEffectKey;
    private string? mediaStateKey;
    private bool mediaLoaded;
    private bool mediaFailed;
    private bool effectFailed;

    [Parameter, EditorRequired]
    public string Src { get; set; } = string.Empty;

    [Parameter]
    public string Alt { get; set; } = string.Empty;

    [Parameter]
    public bool Decorative { get; set; }

    [Parameter]
    public bool Inline { get; set; }

    [Parameter]
    public AppImageEffect Effect { get; set; } = AppImageEffect.None;

    [Parameter]
    public bool FillContainer { get; set; }

    [Parameter]
    public string Fit { get; set; } = "cover";

    [Parameter]
    public string Loading { get; set; } = "lazy";

    [Parameter]
    public string Decoding { get; set; } = "async";

    [Parameter]
    public string? AspectRatio { get; set; }

    [Parameter]
    public string? AdditionalClass { get; set; }

    [Parameter]
    public string? ImageClass { get; set; }

    [Parameter]
    public string? Style { get; set; }

    [Parameter]
    public string? MediaStyle { get; set; }

    [Parameter]
    public int HalftoneSize { get; set; } = 900;

    [Parameter]
    public int HalftoneCell { get; set; } = 8;

    [Parameter]
    public int HalftoneBlackCell { get; set; } = 8;

    [Parameter]
    public int HalftoneReferenceSize { get; set; } = 180;

    [Parameter]
    public double HalftoneUnderlayOpacity { get; set; } = 0.88;

    [Parameter]
    public double HalftoneUnderlayBlur { get; set; } = 0.18;

    [Parameter]
    public bool UseMask { get; set; }

    [Parameter]
    public string MaskColor { get; set; } = "currentColor";

    private string? MaskStyle
    {
        get
        {
            var styles = new List<string>
            {
                $"--app-image-mask-src: url('{Src}')",
                $"--app-image-mask-color: {MaskColor}"
            };

            if (!string.IsNullOrWhiteSpace(MediaStyle))
            {
                styles.Add(MediaStyle);
            }

            return string.Join("; ", styles);
        }
    }

    private string ResolvedAlt => Decorative ? string.Empty : Alt;

    private bool ShouldRenderImage => Effect == AppImageEffect.None || effectFailed;

    private bool ShouldShowLoading => !UseMask
        && !mediaLoaded
        && !mediaFailed
        && !string.IsNullOrWhiteSpace(Src);

    private string? CanvasRole => Decorative ? null : "img";

    private string? CanvasLabel => Decorative ? null : ResolvedAlt;

    private string EffectKey => $"{Src}|{Effect}|{HalftoneSize}|{HalftoneCell}|{HalftoneBlackCell}|{HalftoneReferenceSize}|{HalftoneUnderlayOpacity}|{HalftoneUnderlayBlur}";

    private string MediaStateKey => $"{EffectKey}|{UseMask}|{Fit}|{AspectRatio}";

    private string WrapperClass
    {
        get
        {
            var classes = new List<string> { "app-image" };
            
            if (UseMask)
            {
                classes.Add("app-image--mask");
            }

            if (Inline)
            {
                classes.Add("app-image--inline");
            }

            if (Effect != AppImageEffect.None && !effectFailed)
            {
                classes.Add($"app-image--effect-{Effect.ToString().ToLowerInvariant()}");
            }

            if (!mediaLoaded && !UseMask)
            {
                classes.Add("app-image--loading");
            }

            if (mediaLoaded)
            {
                classes.Add("app-image--loaded");
            }

            if (mediaFailed)
            {
                classes.Add("app-image--failed");
            }

            if (FillContainer)
            {
                classes.Add("app-image--fill");
            }

            classes.Add(Fit == "contain" ? "app-image--contain" : "app-image--cover");

            if (!string.IsNullOrWhiteSpace(AdditionalClass))
            {
                classes.Add(AdditionalClass);
            }

            return string.Join(" ", classes);
        }
    }

    private string MediaClassName => string.IsNullOrWhiteSpace(ImageClass)
        ? "app-image__media"
        : $"app-image__media {ImageClass}";

    private string? ImageStyle => string.IsNullOrWhiteSpace(MediaStyle)
        ? null
        : MediaStyle;

    private string? WrapperStyle
    {
        get
        {
            var styles = new List<string>();

            if (!string.IsNullOrWhiteSpace(AspectRatio))
            {
                styles.Add($"--app-image-aspect-ratio: {AspectRatio}");
            }

            if (!string.IsNullOrWhiteSpace(Style))
            {
                styles.Add(Style);
            }

            return styles.Count == 0 ? null : string.Join("; ", styles);
        }
    }

    protected override void OnParametersSet()
    {
        if (!string.Equals(mediaStateKey, MediaStateKey, StringComparison.Ordinal))
        {
            mediaStateKey = MediaStateKey;
            mediaLoaded = UseMask;
            mediaFailed = false;
            effectFailed = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (UseMask || ShouldRenderImage || string.IsNullOrWhiteSpace(Src) || string.Equals(renderedEffectKey, EffectKey, StringComparison.Ordinal))
        {
            return;
        }

        renderedEffectKey = EffectKey;
        renderCancellation?.Cancel();
        renderCancellation?.Dispose();
        renderCancellation = new CancellationTokenSource();

        bool rendered;
        try
        {
            rendered = await JsRuntime.InvokeAsync<bool>(
                "appImage.renderHalftone",
                renderCancellation.Token,
                canvas,
                Src,
                new
                {
                    size = HalftoneSize,
                    cell = HalftoneCell,
                    blackCell = HalftoneBlackCell,
                    referenceSize = HalftoneReferenceSize,
                    underlayOpacity = HalftoneUnderlayOpacity,
                    underlayBlur = HalftoneUnderlayBlur
                });
        }
        catch (OperationCanceledException)
        {
            return;
        }
        catch (JSException)
        {
            rendered = false;
        }

        if (!rendered)
        {
            effectFailed = true;
            await InvokeAsync(StateHasChanged);
            return;
        }

        mediaLoaded = true;
        await InvokeAsync(StateHasChanged);
    }

    private void HandleImageLoaded()
    {
        mediaLoaded = true;
        mediaFailed = false;
    }

    private void HandleImageError()
    {
        mediaLoaded = false;
        mediaFailed = true;
    }

    public async ValueTask DisposeAsync()
    {
        renderCancellation?.Cancel();
        renderCancellation?.Dispose();
        if (Effect != AppImageEffect.None && renderedEffectKey is not null && !effectFailed)
        {
            await JsRuntime.InvokeVoidAsync("appImage.dispose", canvas);
        }
    }
}
