<div class="@CssClass">
    <div class="app-heading__content">
        @if (!string.IsNullOrWhiteSpace(Eyebrow))
        {
            <span class="app-heading__eyebrow">@Eyebrow</span>
        }

        <h1 class="@TitleClass">@Title</h1>

        @if (!string.IsNullOrWhiteSpace(Subtitle))
        {
            <p class="app-heading__subtitle">@Subtitle</p>
        }
    </div>

    @if (Actions is not null)
    {
        <div class="app-heading__actions">
            @Actions
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string? Subtitle { get; set; }

    [Parameter]
    public string? Eyebrow { get; set; }

    [Parameter]
    public string Level { get; set; } = "page";

    [Parameter]
    public RenderFragment? Actions { get; set; }

    private string CssClass => $"app-heading app-heading--{Level}";

    private string TitleClass => Level switch
    {
        "section" => "app-heading__title app-heading__title--section",
        _ => "app-heading__title"
    };
}
