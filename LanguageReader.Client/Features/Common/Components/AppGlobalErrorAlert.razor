@implements IDisposable
@inject AppErrorService Errors

@if (Errors.Current is { } error)
{
    <div class="app-global-error" role="alert" aria-live="assertive">
        <AppAlert Tone="error"
                  Title="@error.Title"
                  Message="@error.Message" />
        <button type="button"
                class="app-global-error__close"
                aria-label="Dismiss error"
                @onclick="Errors.Clear">
            <AppIcon Name="close" Size="18" />
        </button>
    </div>
}

@code {
    protected override void OnInitialized()
    {
        Errors.Changed += HandleChanged;
    }

    private void HandleChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Errors.Changed -= HandleChanged;
    }
}
