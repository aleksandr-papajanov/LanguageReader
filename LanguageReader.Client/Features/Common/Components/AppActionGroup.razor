<div class="@CssClass">
    @ChildContent
</div>

@code {
    [Parameter]
    public bool Wrap { get; set; } = true;

    [Parameter]
    public string? AdditionalClass { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    private string CssClass
    {
        get
        {
            var wrapClass = Wrap ? "app-action-group--wrap" : "app-action-group--nowrap";
            return string.IsNullOrWhiteSpace(AdditionalClass)
                ? $"app-action-group {wrapClass}"
                : $"app-action-group {wrapClass} {AdditionalClass}";
        }
    }
}
