<section class="@CssClass">
    @ChildContent
</section>

@code {
    [Parameter]
    public string? AdditionalClass { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    private string CssClass => string.IsNullOrWhiteSpace(AdditionalClass)
        ? "app-panel"
        : $"app-panel {AdditionalClass}";
}
