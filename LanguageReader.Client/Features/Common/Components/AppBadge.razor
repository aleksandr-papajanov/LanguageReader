@if (!string.IsNullOrWhiteSpace(Href))
{
    <a class="@CssClass"
       href="@Href"
       target="@Target"
       rel="@Rel"
       title="@Title">
        <span class="app-badge__content">@ChildContent</span>
    </a>
}
else
{
    <span class="@CssClass" title="@Title">
        <span class="app-badge__content">@ChildContent</span>
    </span>
}

@code {
    [Parameter]
    public string Tone { get; set; } = "default";

    [Parameter]
    public bool PreserveCase { get; set; }

    [Parameter]
    public bool Compact { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public string? Href { get; set; }

    [Parameter]
    public string? Title { get; set; }

    [Parameter]
    public string Target { get; set; } = "_blank";

    [Parameter]
    public string Rel { get; set; } = "noreferrer";

    private string CssClass =>
        $"app-badge app-badge--{Tone}" +
        $"{(PreserveCase ? " app-badge--preserve-case" : string.Empty)}" +
        $"{(Compact ? " app-badge--compact" : string.Empty)}";
}
