<section class="@CssClass">
    <div class="app-section__header">
        <div class="app-section__title-wrap">
            <h2 class="app-section__title">@Title</h2>
            @if (!string.IsNullOrWhiteSpace(Subtitle))
            {
                <p class="app-section__subtitle">@Subtitle</p>
            }
        </div>

        @if (Actions is not null)
        {
            <div class="app-section__actions">
                @Actions
            </div>
        }
    </div>

    @if (WrapBodyInPanel)
    {
        <AppPanel AdditionalClass="app-section__surface">
            <div class="app-section__body">
                @ChildContent
            </div>
        </AppPanel>
    }
    else
    {
        <div class="app-section__body">
            @ChildContent
        </div>
    }
</section>

@code {
    [Parameter, EditorRequired]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string? Subtitle { get; set; }

    [Parameter]
    public string? AdditionalClass { get; set; }

    [Parameter]
    public RenderFragment? Actions { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public bool WrapBodyInPanel { get; set; } = true;

    private string CssClass => string.IsNullOrWhiteSpace(AdditionalClass)
        ? "app-section"
        : $"app-section {AdditionalClass}";
}
