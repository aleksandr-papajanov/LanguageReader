@using LanguageReader.Client.Features.ReadingItems.Components
@using LanguageReader.Client.Features.ReadingItems.Services
@using LanguageReader.Client.Features.Users.Services
@using LanguageReader.Shared.Features.News
@using LanguageReader.Shared.Features.ReadingItems
@inject NewsApiClient NewsApi
@inject ReadingItemsApiClient ReadingItemsApi
@inject ReaderWorkspaceService ReaderWorkspace
@inject NavigationManager Navigation
@inject UserSession Session
@inject AppErrorService Errors

<AppHeading Title="News" Subtitle="Fresh articles you can save into your reading library." />

<section class="news-shell">
    <div class="news-header-row">
        <ReadingItemSourceMark SourceKey="@activeSourceKey" Size="lg" />
    </div>

        <AppTabs Items="sourceTabs"
                 ActiveValue="@activeSourceKey"
                 ActiveValueChanged="SelectSourceAsync"
                 AriaLabel="News sources" />
             
    @if (isLoading)
    {
        <AppLoader Label="Loading news" />
    }
    else if (isSwitchingSource)
    {
        <AppLoader Label="Switching source" />
    }
    else if (items.Count == 0 && string.IsNullOrWhiteSpace(errorMessage))
    {
        <AppAlert Tone="info"
                  Title="No articles yet"
                  Message="This source did not return any readable articles right now." />
    }

    <AppSection Title="Latest news">
        @if (!isLoading && !isSwitchingSource)
        {
            <ReadingItemList Items="items"
                             EmptyMessage="No news items found."
                             BusyItemId="busyItemId"
                             PrimaryActionSelected="HandlePrimaryActionAsync"
                             VisibilityToggleSelected="ToggleVisibilityAsync"
                             DeleteSelected="DeleteSavedAsync"
                             OpenOriginalSelected="OpenOriginalAsync" />
        }
    </AppSection>
</section>

<ReadingItemImportPreviewModal IsOpen="@isPreviewOpen"
                               Preview="@articlePreview"
                               ErrorMessage="@articlePreviewError"
                               IsBusy="@isImportingPreview"
                               IsLoading="@isPreviewingArticle"
                               Title="Review article"
                               Eyebrow="Readable article"
                               ConfirmLabel="Save and open"
                               Confirmed="ConfirmArticleImportAsync"
                               Closed="CloseArticlePreview" />

@code {
    private List<ReadingItemSummaryDto> items = [];
    private readonly IReadOnlyList<AppTabItem> sourceTabs = ReadingItemSourceCatalog.ToTabs();
    private string activeSourceKey = NewsSourceKeys.Svt;
    private Guid? busyItemId;
    private ReadingItemSummaryDto? previewItem;
    private ReadingItemImportPreviewDto? articlePreview;
    private string? articlePreviewError;
    private string? errorMessage;
    private bool isLoading;
    private bool isSwitchingSource;
    private bool isPreviewOpen;
    private bool isPreviewingArticle;
    private bool isImportingPreview;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync(showInitialLoading: true);
    }

    private async Task LoadAsync(bool showInitialLoading = false)
    {
        errorMessage = null;

        if (string.IsNullOrWhiteSpace(Session.Username))
        {
            items = [];
            return;
        }

        if (showInitialLoading)
        {
            isLoading = true;
        }

        try
        {
            items = (await ReadingItemsApi.GetReadingItemsAsync(
                new GetReadingItemsRequest(
                    Session.Username,
                    Collection: ReadingItemCollectionFilter.Discover,
                    SourceKey: activeSourceKey),
                CancellationToken.None)).ToList();
        }
        catch (Exception exception)
        {
            items = [];
            errorMessage = exception.Message;
            Errors.Show(exception);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandlePrimaryActionAsync(ReadingItemSummaryDto item)
    {
        if (item.CanImport)
        {
            await PreviewArticleAsync(item);
            return;
        }

        if (!item.CanOpen && !item.CanContinue)
        {
            return;
        }

        ReaderWorkspace.Open(item.Id);
    }

    private async Task PreviewArticleAsync(ReadingItemSummaryDto item)
    {
        if (string.IsNullOrWhiteSpace(Session.Username) || string.IsNullOrWhiteSpace(item.OriginalUrl))
        {
            return;
        }

        busyItemId = item.Id;
        errorMessage = null;
        articlePreview = null;
        articlePreviewError = null;
        previewItem = item;
        isPreviewOpen = true;
        isPreviewingArticle = true;

        try
        {
            articlePreview = await NewsApi.PreviewArticleAsync(
                new PreviewNewsArticleRequest(item.SourceKey ?? NewsSourceKeys.Svt, item.OriginalUrl),
                CancellationToken.None);
            articlePreviewError = null;
        }
        catch (Exception exception)
        {
            articlePreview = null;
            articlePreviewError = exception.Message;
            Errors.Show(exception);
        }
        finally
        {
            busyItemId = null;
            isPreviewingArticle = false;
        }
    }

    private async Task ConfirmArticleImportAsync()
    {
        if (previewItem is null
            || string.IsNullOrWhiteSpace(Session.Username)
            || string.IsNullOrWhiteSpace(previewItem.OriginalUrl))
        {
            return;
        }

        busyItemId = previewItem.Id;
        isImportingPreview = true;
        errorMessage = null;

        try
        {
            var result = await NewsApi.ImportArticleAsync(
                new ImportNewsArticleRequest(
                    Session.Username,
                    previewItem.SourceKey ?? NewsSourceKeys.Svt,
                    previewItem.OriginalUrl),
                CancellationToken.None);

            CloseArticlePreview();
            await LoadAsync();
            ReaderWorkspace.Open(result.Id);
        }
        catch (Exception exception)
        {
            errorMessage = exception.Message;
            Errors.Show(exception);
        }
        finally
        {
            busyItemId = null;
            isImportingPreview = false;
        }
    }

    private void CloseArticlePreview()
    {
        isPreviewOpen = false;
        articlePreview = null;
        articlePreviewError = null;
        previewItem = null;
        isPreviewingArticle = false;
    }

    private async Task ToggleVisibilityAsync(ReadingItemSummaryDto item)
    {
        if (string.IsNullOrWhiteSpace(Session.Username) || (!item.CanPublish && !item.CanUnpublish))
        {
            return;
        }

        busyItemId = item.Id;
        errorMessage = null;

        try
        {
            await ReadingItemsApi.SetVisibilityAsync(
                new UpdateReadingItemVisibilityRequest(item.Id, Session.Username, !item.IsPublic),
                CancellationToken.None);
        }
        catch (Exception exception)
        {
            errorMessage = exception.Message;
            Errors.Show(exception);
        }
        finally
        {
            busyItemId = null;
            await LoadAsync();
        }
    }

    private async Task DeleteSavedAsync(ReadingItemSummaryDto item)
    {
        if (string.IsNullOrWhiteSpace(Session.Username) || !item.CanDelete)
        {
            return;
        }

        busyItemId = item.Id;
        errorMessage = null;

        try
        {
            await ReadingItemsApi.DeleteReadingItemAsync(
                new DeleteReadingItemRequest(item.Id, Session.Username),
                CancellationToken.None);
        }
        catch (Exception exception)
        {
            errorMessage = exception.Message;
            Errors.Show(exception);
        }
        finally
        {
            busyItemId = null;
            await LoadAsync();
        }
    }

    private Task OpenOriginalAsync(ReadingItemSummaryDto item)
    {
        if (!string.IsNullOrWhiteSpace(item.OriginalUrl))
        {
            Navigation.NavigateTo(item.OriginalUrl, forceLoad: true);
        }

        return Task.CompletedTask;
    }

    private async Task SelectSourceAsync(string sourceKey)
    {
        if (string.IsNullOrWhiteSpace(sourceKey) || string.Equals(activeSourceKey, sourceKey, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        activeSourceKey = sourceKey;
        isSwitchingSource = true;
        try
        {
            await LoadAsync();
        }
        finally
        {
            isSwitchingSource = false;
        }
    }
}
