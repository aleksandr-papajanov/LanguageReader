@inject UserSession Session
@inject NavigationManager Navigation
@implements IDisposable

<div class="top-row">
    @if (ShowBackButton)
    {
        <AppButton Variant="ghost"
                   Size="sm"
                   Icon="arrow_back"
                   IconOnly="true"
                   Title="Back"
                   OnClick="@(_ => NavigateBackAsync())" />
    }

    @if (Session.IsSignedIn)
    {
        <div class="session-status">
            <span class="session-status__label">Signed in as</span>
            <strong class="session-status__user">@Session.Username</strong>
        </div>
        <AppButton Variant="ghost"
                   Size="sm"
                   Icon="logout"
                   IconOnly="true"
                   Title="Logout"
                   OnClick="@(_ => LogoutAsync())" />
    }
    else
    {
        <NavLink class="session-link" href="login">Login</NavLink>
    }
</div>

@code {
    protected override void OnInitialized()
    {
        Session.Changed += OnSessionChanged;
        Navigation.LocationChanged += OnLocationChanged;
    }

    private string CurrentPath => Navigation.ToBaseRelativePath(Navigation.Uri);

    private bool ShowBackButton =>
        CurrentPath.StartsWith("reader/", StringComparison.OrdinalIgnoreCase)
        || CurrentPath.StartsWith("words/", StringComparison.OrdinalIgnoreCase);

    private async Task LogoutAsync()
    {
        await Session.SignOutAsync();
        Navigation.NavigateTo("login");
    }

    private Task NavigateBackAsync()
    {
        if (CurrentPath.StartsWith("words/", StringComparison.OrdinalIgnoreCase))
        {
            var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
            var returnUrl = GetQueryValue(uri.Query, "returnUrl");
            if (!string.IsNullOrWhiteSpace(returnUrl))
            {
                Navigation.NavigateTo(Uri.UnescapeDataString(returnUrl));
                return Task.CompletedTask;
            }

            Navigation.NavigateTo("/vocabulary");
            return Task.CompletedTask;
        }

        if (CurrentPath.StartsWith("reader/", StringComparison.OrdinalIgnoreCase))
        {
            Navigation.NavigateTo("/");
            return Task.CompletedTask;
        }

        Navigation.NavigateTo(string.Empty);
        return Task.CompletedTask;
    }

    private void OnSessionChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Session.Changed -= OnSessionChanged;
        Navigation.LocationChanged -= OnLocationChanged;
    }

    private static string? GetQueryValue(string query, string key)
    {
        if (string.IsNullOrWhiteSpace(query))
        {
            return null;
        }

        var trimmed = query.TrimStart('?');
        foreach (var pair in trimmed.Split('&', StringSplitOptions.RemoveEmptyEntries))
        {
            var parts = pair.Split('=', 2);
            if (parts.Length == 2 && string.Equals(parts[0], key, StringComparison.OrdinalIgnoreCase))
            {
                return parts[1];
            }
        }

        return null;
    }
}
