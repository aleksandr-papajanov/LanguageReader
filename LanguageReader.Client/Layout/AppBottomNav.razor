@inject NavigationManager Navigation
@inject ReaderWorkspaceService ReaderWorkspace
@inject IJSRuntime JsRuntime
@implements IDisposable

<nav class="@NavClass" aria-label="Primary navigation">
    <div class="bottom-nav__scroller"
         tabindex="0"
         @ref="scroller"
         @onwheel="ScrollWithWheelAsync"
         @onwheel:preventDefault>
        <AppNavItem Href=""
                    Match="NavLinkMatch.All"
                    Icon="shelves"
                    IconSize="23"
                    Label="Library"
                    Layout="Vertical"
                    Justify="center"
                    Align="center"
                    Active="@IsRouteActive("")"
                    Clicked="@ShowLibraryAsync"
                    AdditionalClass="bottom-nav__item" />

        <AppNavItem Href=""
                    Icon="auto_stories"
                    IconSize="23"
                    Label="Reader"
                    Layout="Vertical"
                    Justify="center"
                    Align="center"
                    Active="@(ReaderWorkspace.Mode == ReaderWorkspaceMode.Reader)"
                    Disabled="@(!ReaderWorkspace.IsReaderAvailable)"
                    Clicked="@ShowReaderAsync"
                    AdditionalClass="bottom-nav__item" />

        <AppNavItem Href="news"
                    Icon="feed"
                    IconSize="23"
                    Label="News"
                    Layout="Vertical"
                    Justify="center"
                    Align="center"
                    Active="@IsNewsActive"
                    Clicked="@ShowNewsAsync"
                    AdditionalClass="bottom-nav__item" />

        <AppNavItem Href="vocabulary"
                    Icon="spellcheck"
                    IconSize="23"
                    Label="Words"
                    Layout="Vertical"
                    Justify="center"
                    Align="center"
                    Active="@IsVocabularyActive"
                    Clicked="@ShowVocabularyAsync"
                    AdditionalClass="bottom-nav__item" />

        <AppNavItem Href="training"
                    Icon="school"
                    IconSize="23"
                    Label="Train"
                    Layout="Vertical"
                    Justify="center"
                    Align="center"
                    Active="@IsTrainingActive"
                    Clicked="@ShowTrainingAsync"
                    AdditionalClass="bottom-nav__item" />

        <AppNavItem Href="settings"
                    Icon="tune"
                    IconSize="23"
                    Label="Settings"
                    Layout="Vertical"
                    Justify="center"
                    Align="center"
                    Active="@IsSettingsActive"
                    Clicked="@ShowSettingsAsync"
                    AdditionalClass="bottom-nav__item" />
    </div>
</nav>

@code {
    [Parameter]
    public bool Embedded { get; set; }

    private ElementReference scroller;

    private string NavClass => Embedded
        ? "bottom-nav bottom-nav--embedded"
        : "bottom-nav";

    private string CurrentPath => Navigation
        .ToBaseRelativePath(Navigation.Uri)
        .Split('?', '#')[0]
        .Trim('/')
        .ToLowerInvariant();

    private bool IsNewsActive => IsRouteActive("news");

    private bool IsVocabularyActive => IsRouteActive("vocabulary");

    private bool IsTrainingActive => IsRouteActive("training");

    private bool IsSettingsActive => IsRouteActive("settings");

    private bool IsRouteActive(string route)
    {
        if (ReaderWorkspace.Mode == ReaderWorkspaceMode.Reader)
        {
            return false;
        }

        var normalizedRoute = route.Trim('/').ToLowerInvariant();
        return string.IsNullOrWhiteSpace(normalizedRoute)
            ? string.IsNullOrWhiteSpace(CurrentPath)
            : CurrentPath.StartsWith(normalizedRoute, StringComparison.Ordinal);
    }

    protected override void OnInitialized()
    {
        ReaderWorkspace.Changed += HandleReaderWorkspaceChanged;
    }

    private void HandleReaderWorkspaceChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private Task ShowReaderAsync(MouseEventArgs _)
    {
        ReaderWorkspace.ShowReader();
        return Task.CompletedTask;
    }

    private Task ShowMainAndNavigateAsync(string route)
    {
        Navigation.NavigateTo(route);
        ReaderWorkspace.ShowMain();
        return Task.CompletedTask;
    }

    private Task ShowLibraryAsync(MouseEventArgs _)
        => ShowMainAndNavigateAsync("");

    private Task ShowNewsAsync(MouseEventArgs _)
        => ShowMainAndNavigateAsync("news");

    private Task ShowVocabularyAsync(MouseEventArgs _)
        => ShowMainAndNavigateAsync("vocabulary");

    private Task ShowTrainingAsync(MouseEventArgs _)
        => ShowMainAndNavigateAsync("training");

    private Task ShowSettingsAsync(MouseEventArgs _)
        => ShowMainAndNavigateAsync("settings");

    private async Task ScrollWithWheelAsync(WheelEventArgs args)
    {
        var delta = Math.Abs(args.DeltaX) > Math.Abs(args.DeltaY)
            ? args.DeltaX
            : args.DeltaY;

        await JsRuntime.InvokeVoidAsync("languageReaderSelection.scrollElementHorizontally", scroller, delta);
    }

    public void Dispose()
    {
        ReaderWorkspace.Changed -= HandleReaderWorkspaceChanged;
    }
}
